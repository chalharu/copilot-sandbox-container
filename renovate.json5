{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": [
		"config:recommended",
		"docker:pinDigests",
		":disableRateLimiting",
		"helpers:pinGitHubActionDigests",
		":dependencyDashboard"
	],
	"timezone": "Asia/Tokyo",
	"configMigration": true,
	"configWarningReuseIssue": false,
	"labels": [
		"renovate"
	],
	"rebaseWhen": "behind-base-branch",
	"pruneStaleBranches": true,
	"separateMajorMinor": true,
	"separateMinorPatch": true,
	"separateMultipleMajor": true,
	"separateMultipleMinor": true,
	"automerge": true,
	"automergeStrategy": "auto",
	"platformAutomerge": false,
	"pinDigests": true,
	"internalChecksFilter": "none",
	"prCreation": "immediate",
	"vulnerabilityAlerts": {
		"enabled": true,
		"labels": [
			"renovate",
			"security"
		],
		"minimumReleaseAge": null
	},
	configMigration: true,
	timezone: "Asia/Tokyo",
	"rangeStrategy": "pin",
	"minimumReleaseAge": "3 days",
	"minimumReleaseAgeBehaviour": "timestamp-required",
	packageRules: [
		{
			description: "Opt @github/copilot into a 1-day merge gate via labels",
			matchPackageNames: ["@github/copilot"],
			matchUpdateTypes: ["major", "minor", "patch"],
			"minimumReleaseAge": "1 day"
		},
		{
			description: "Keep setup-kind manually pinned while the upstream v0.6.2 tag points at the wrong commit",
			matchManagers: ["github-actions"],
			matchPackageNames: ["engineerd/setup-kind"],
			enabled: false
		}
	],
	customManagers: [
		{
			customType: "regex",
			managerFilePatterns: ["/^containers\\/control-plane\\/config\\/external-skills\\.yaml$/"],
			matchStrings: [
				"- repository:\\s*(?<depName>\\S+)\\s+ref:\\s*(?<currentDigest>[a-f0-9]{40})\\s+# renovate: datasource=(?<datasource>\\S+) currentValue=(?<currentValue>\\S+)"
			]
		},
		{
			customType: "regex",
			managerFilePatterns: [
				"/^scripts\\/(lint|test-github-hooks|test-kind|test-k8s-sample-storage-layout|lib-biome-hook-image)\\.sh$/"
			],
			matchStrings: [
				"# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: versioning=(?<versioning>\\S+))?\\s+(?:export\\s+)?[a-z_]+=\"\\$\\{[A-Z0-9_]+:-[^:@\"}]+:(?<currentValue>[^@\"}]+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?\\}\"",
				"# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: versioning=(?<versioning>\\S+))?\\s+(?:export\\s+)?[a-z_]+=\"\\$\\{[A-Z0-9_]+:-(?<currentValue>[A-Za-z0-9._-]+)\\}\""
			]
		},
		{
			customType: "regex",
			managerFilePatterns: [
				"/^containers\\/(control-plane|exec-pod)\\/Dockerfile$/"
			],
			// Chrome for Testing in containers/exec-pod/Dockerfile is updated manually
			// because the pinned Linux64 archive digests must move together with the
			// version and the official CfT metadata does not publish those digests.
			matchStrings: [
				"# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: versioning=(?<versioning>\\S+))?\\s+ARG [A-Z0-9_]+=(?<currentValue>\\S+)"
			]
		},
		{
			customType: "regex",
			managerFilePatterns: [
				"/^(deploy\\/helm\\/control-plane\\/values\\.yaml|deploy\\/kubernetes\\/control-plane\\.example\\/common\\/configmap-control-plane-env\\.yaml)$/"
			],
			matchStrings: [
				"# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: versioning=(?<versioning>\\S+))?\\s+CONTROL_PLANE_(?:BIOME|RUST)_HOOK_IMAGE:\\s+\"?[^:@\\s\"]+:(?<currentValue>[^@\\s\"]+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?\"?"
			]
		},
		{
			customType: "regex",
			managerFilePatterns: ["/^(deploy\\/kubernetes\\/control-plane\\.example\\.yaml|scripts\\/test-kind\\.sh)$/"],
			matchStrings: [
				"# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: versioning=(?<versioning>\\S+))?\\s+image:\\s+[^:@\\s]+:(?<currentValue>[^@\\s]+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?"
			]
		}
	]
}
