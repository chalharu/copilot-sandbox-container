{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",

  extends: [
    "config:recommended",
    "docker:pinDigests",
    "helpers:pinGitHubActionDigests",
    ":disableRateLimiting",
  ],

  enabledManagers: ["dockerfile", "github-actions", "custom.regex"],

  labels: ["dependencies", "renovate"],
  dependencyDashboard: true,
  prCreation: "immediate",
  rebaseWhen: "behind-base-branch",
  timezone: "Asia/Tokyo",
  automergeStrategy: "auto",
  vulnerabilityAlerts: {
    enabled: true,
    labels: ["dependencies", "renovate"],
    automerge: true,
    automergeType: "pr",
    platformAutomerge: true,
    minimumReleaseAge: null,
  },
  minor: {
    automerge: true,
    automergeType: "pr",
    platformAutomerge: true,
    minimumReleaseAge: "3 days",
  },
  patch: {
    automerge: true,
    automergeType: "pr",
    platformAutomerge: true,
    minimumReleaseAge: "3 days",
  },
  digest: {
    automerge: true,
    automergeType: "pr",
    platformAutomerge: true,
    minimumReleaseAge: "3 days",
  },
  pin: {
    automerge: true,
    automergeType: "pr",
    platformAutomerge: true,
    minimumReleaseAge: "3 days",
  },
  pinDigest: {
    automerge: true,
    automergeType: "pr",
    platformAutomerge: true,
    minimumReleaseAge: "3 days",
  },

  packageRules: [
    {
      description: "Automerge @github/copilot after GitHub Actions succeeds and 1 day of release age",
      matchPackageNames: ["@github/copilot"],
      automerge: true,
      automergeType: "pr",
      platformAutomerge: true,
      minimumReleaseAge: "1 day",
    },
    {
      description: "Override the helper preset for actions/* GitHub Actions",
      matchManagers: ["github-actions"],
      matchPackageNames: ["/^actions\\/.+$/"],
      pinDigests: false,
    },
    {
      description: "Keep DHI base images aligned across yamllint",
      matchPackageNames: ["dhi.io/python"],
      groupName: "yamllint DHI python images",
      groupSlug: "yamllint-dhi-python",
      separateMajorMinor: false,
      separateMinorPatch: false,
    },
    {
      description: "Keep setup-kind manually pinned while the upstream v0.6.2 tag points at the wrong commit",
      matchManagers: ["github-actions"],
      matchPackageNames: ["engineerd/setup-kind"],
      enabled: false,
    },
  ],

  customManagers: [
    {
      customType: "regex",
      managerFilePatterns: ["/^scripts\\/(lint|validate-renovate-config)\\.sh$/"],
      matchStrings: [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: versioning=(?<versioning>\\S+))?\\s+[a-z_]+=\"\\$\\{[A-Z0-9_]+:-[^:@\"}]+:(?<currentValue>[^@\"}]+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?\\}\"",
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: versioning=(?<versioning>\\S+))?\\s+[a-z_]+=\"\\$\\{[A-Z0-9_]+:-(?<currentValue>[A-Za-z0-9._-]+)\\}\"",
      ],
    },
    {
      customType: "regex",
      managerFilePatterns: ["/^containers\\/(control-plane|yamllint)\\/Dockerfile$/"],
      matchStrings: [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: versioning=(?<versioning>\\S+))?\\s+ARG [A-Z0-9_]+=(?<currentValue>\\S+)",
      ],
    },
    {
      customType: "regex",
      managerFilePatterns: ["/^(deploy\\/kubernetes\\/control-plane\\.example\\.yaml|scripts\\/test-kind\\.sh)$/"],
      matchStrings: [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: versioning=(?<versioning>\\S+))?\\s+image:\\s+[^:@\\s]+:(?<currentValue>[^@\\s]+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?",
      ],
    },
  ],
}
