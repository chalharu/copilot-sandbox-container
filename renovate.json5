{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",

  extends: [
    "config:recommended",
    "docker:pinDigests",
    "helpers:pinGitHubActionDigests",
    ":disableRateLimiting",
  ],

  enabledManagers: ["dockerfile", "github-actions", "custom.regex"],

  labels: ["dependencies"],
  dependencyDashboard: true,
  prCreation: "immediate",
  rebaseWhen: "behind-base-branch",
  timezone: "Asia/Tokyo",
  automergeStrategy: "auto",

  packageRules: [
    {
      description: "Automerge non-major updates after GitHub Actions succeeds",
      matchUpdateTypes: ["minor", "patch", "digest", "pin", "pinDigest"],
      automerge: true,
      automergeType: "pr",
      platformAutomerge: true,
    },
    {
      description: "Override the helper preset for actions/* GitHub Actions",
      matchManagers: ["github-actions"],
      matchPackageNames: ["/^actions\\/.+$/"],
      pinDigests: false,
    },
    {
      description: "Keep DHI base images aligned across yamllint and cache preparation",
      matchPackageNames: ["dhi.io/python"],
      groupName: "yamllint DHI python images",
      groupSlug: "yamllint-dhi-python",
      separateMajorMinor: false,
      separateMinorPatch: false,
    },
  ],

  customManagers: [
    {
      customType: "regex",
      managerFilePatterns: ["/^scripts\\/(lint|validate-renovate-config)\\.sh$/"],
      matchStrings: [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: versioning=(?<versioning>\\S+))?\\s+[a-z_]+=\"\\$\\{[A-Z0-9_]+:-[^:\"}]+:(?<currentValue>[^\"}]+)\\}\"",
      ],
    },
    {
      customType: "regex",
      managerFilePatterns: ["/^scripts\\/prepare-dhi-images\\.sh$/"],
      matchStrings: [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: versioning=(?<versioning>\\S+))?\\s+\"[^:\"]+:(?<currentValue>[^\"]+)\"",
      ],
    },
    {
      customType: "regex",
      managerFilePatterns: ["/^containers\\/yamllint\\/Dockerfile$/"],
      matchStrings: [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: versioning=(?<versioning>\\S+))?\\s+ARG [A-Z0-9_]+=(?<currentValue>\\S+)",
      ],
    },
  ],
}
