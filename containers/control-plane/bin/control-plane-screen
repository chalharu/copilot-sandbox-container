#!/usr/bin/env bash
set -euo pipefail

runtime_config_file="${CONTROL_PLANE_RUNTIME_ENV_FILE:-${HOME:-/home/${USER:-copilot}}/.config/control-plane/runtime.env}"
if [[ -f "${runtime_config_file}" ]]; then
  # shellcheck disable=SC1090
  source "${runtime_config_file}"
fi

screen_runtime_root="${XDG_RUNTIME_DIR:-${HOME:-/tmp}/.copilot/run}"
export SCREENDIR="${SCREENDIR:-${screen_runtime_root%/}/screen}"
mkdir -p "${SCREENDIR}"
chmod 700 "${SCREENDIR}"

case "${TERM:-}" in
  '' | dumb)
    export TERM=xterm
    ;;
esac

exec /usr/bin/screen "$@"
