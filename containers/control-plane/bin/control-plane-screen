#!/usr/bin/env bash
set -euo pipefail

runtime_config_file="${CONTROL_PLANE_RUNTIME_ENV_FILE:-${HOME:-/home/${USER:-copilot}}/.config/control-plane/runtime.env}"
if [[ -f "${runtime_config_file}" ]]; then
  # shellcheck disable=SC1090
  source "${runtime_config_file}"
fi

ensure_compatible_term() {
  local candidate

  if TERM="${TERM:-}" tput clear >/dev/null 2>&1; then
    return
  fi

  for candidate in xterm-256color xterm; do
    if TERM="${candidate}" tput clear >/dev/null 2>&1; then
      export TERM="${candidate}"
      return
    fi
  done

  export TERM=xterm
}

ensure_compatible_term

screen_runtime_root="${XDG_RUNTIME_DIR:-${HOME:-/tmp}/.copilot/run}"
export SCREENDIR="${SCREENDIR:-${screen_runtime_root%/}/screen}"
mkdir -p "${SCREENDIR}"
chmod 700 "${SCREENDIR}"

exec /usr/bin/screen "$@"
