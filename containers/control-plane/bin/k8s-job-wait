#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  k8s-job-wait --namespace NAME --job-name NAME [--timeout 300s]
USAGE
}

die() {
  printf 'k8s-job-wait: %s\n' "$*" >&2
  exit 64
}

namespace="default"
job_name=""
timeout="300s"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --namespace)
      namespace="$2"
      shift 2
      ;;
    --job-name)
      job_name="$2"
      shift 2
      ;;
    --timeout)
      timeout="$2"
      shift 2
      ;;
    --help)
      usage
      exit 0
      ;;
    *)
      die "unknown option: $1"
      ;;
  esac
done

[[ -n "${job_name}" ]] || die "--job-name is required"

command -v kubectl >/dev/null 2>&1 || die "kubectl is required"
command -v timeout >/dev/null 2>&1 || die "timeout is required"

set +e
CONTROL_PLANE_WAIT_NAMESPACE="${namespace}" \
CONTROL_PLANE_WAIT_JOB_NAME="${job_name}" \
timeout "${timeout}" bash -s <<'EOF'
set -euo pipefail

while true; do
  job_conditions="$(
    kubectl get job "${CONTROL_PLANE_WAIT_JOB_NAME}" \
      --namespace "${CONTROL_PLANE_WAIT_NAMESPACE}" \
      -o jsonpath='{range .status.conditions[*]}{.type}={.status}{"\n"}{end}' 2>/dev/null || true
  )"

  if grep -qx 'Complete=True' <<<"${job_conditions}"; then
    exit 0
  fi

  if grep -qx 'Failed=True' <<<"${job_conditions}"; then
    exit 1
  fi

  sleep 1
done
EOF
wait_status=$?
set -e

case "${wait_status}" in
  0)
    exit 0
    ;;
  1)
    printf 'k8s-job-wait: job %s failed\n' "${job_name}" >&2
    exit 1
    ;;
  124)
    printf 'k8s-job-wait: timed out waiting for job %s\n' "${job_name}" >&2
    exit 124
    ;;
  *)
    exit "${wait_status}"
    ;;
esac
