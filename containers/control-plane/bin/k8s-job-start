#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  k8s-job-start --namespace NAME --image IMAGE [--job-name NAME] [--mount-file SRC[:DEST]] -- COMMAND [ARG...]

Namespace default:
  CONTROL_PLANE_JOB_NAMESPACE, then CONTROL_PLANE_K8S_NAMESPACE, then default
USAGE
}

die() {
  printf 'k8s-job-start: %s\n' "$*" >&2
  exit 64
}

runtime_config_file="${CONTROL_PLANE_RUNTIME_ENV_FILE:-${HOME:-/home/${USER:-copilot}}/.config/control-plane/runtime.env}"
if [[ -f "${runtime_config_file}" ]]; then
  # shellcheck disable=SC1090
  source "${runtime_config_file}"
fi

yaml_quote() {
  local value="$1"
  value="${value//\'/\'\'}"
  printf "'%s'" "${value}"
}

render_yaml_list() {
  local indent="$1"
  shift
  local item
  for item in "$@"; do
    printf '%s- %s\n' "${indent}" "$(yaml_quote "${item}")"
  done
}

append_yaml_block() {
  local existing="$1"
  local block="$2"

  if [[ -n "${existing}" ]]; then
    printf '%s\n%s' "${existing}" "${block}"
  else
    printf '%s' "${block}"
  fi
}

validate_relative_path() {
  local relative_path="$1"
  local allow_colon="${2:-0}"
  local segment

  [[ -n "${relative_path}" ]] || die "mount-file destination must not be empty"
  [[ "${relative_path}" != /* ]] || die "mount-file destination must stay under the input mount path"

  IFS='/' read -r -a path_segments <<< "${relative_path}"
  for segment in "${path_segments[@]}"; do
    [[ -n "${segment}" ]] || die "mount-file destination must not contain empty path segments"
    [[ "${segment}" != "." ]] || die "mount-file destination must not contain '.' segments"
    [[ "${segment}" != ".." ]] || die "mount-file destination must not contain '..' segments"
  done
  if [[ "${allow_colon}" != "1" ]]; then
    [[ "${relative_path}" != *:* ]] || die "mount-file destination must not contain ':'"
  fi
}

normalize_mount_file_spec() {
  local spec="$1"
  local source_path
  local destination_path
  local allow_colon=0

  if [[ -f "${spec}" ]]; then
    source_path="${spec}"
    destination_path="$(basename "${spec}")"
    allow_colon=1
  elif [[ "${spec}" == *:* ]]; then
    source_path="${spec%:*}"
    destination_path="${spec##*:}"
  else
    source_path="${spec}"
    destination_path="$(basename "${spec}")"
  fi

  [[ -n "${source_path}" ]] || die "mount-file source must not be empty"
  [[ -f "${source_path}" ]] || die "mount-file source is not a regular file: ${source_path}"
  [[ ! -L "${source_path}" ]] || die "mount-file source must not be a symlink: ${source_path}"
  validate_relative_path "${destination_path}" "${allow_colon}"

  printf '%s\t%s\n' "${source_path}" "${destination_path}"
}

job_transfer_secret_name() {
  local current_job_name="$1"
  local checksum
  local prefix

  checksum="$(printf '%s' "${current_job_name}" | cksum | awk '{ print $1 }')"
  prefix="${current_job_name:0:43}"
  prefix="${prefix%-}"
  printf '%s-transfer-%s\n' "${prefix}" "${checksum}"
}

append_authorized_key_block() {
  local marker="$1"
  local public_key_path="$2"
  local lock_file="${authorized_keys_path}.lock"

  touch "${authorized_keys_path}"
  chmod 600 "${authorized_keys_path}"

  (
    flock -x 9
    if grep -Fxq "# BEGIN ${marker}" "${authorized_keys_path}"; then
      die "authorized_keys already contains marker ${marker}"
    fi
    {
      printf '# BEGIN %s\n' "${marker}"
      cat "${public_key_path}"
      printf '# END %s\n' "${marker}"
    } >> "${authorized_keys_path}"
  ) 9>"${lock_file}"
}

namespace="${CONTROL_PLANE_JOB_NAMESPACE:-${CONTROL_PLANE_K8S_NAMESPACE:-default}}"
image=""
job_name=""
workspace_pvc="${CONTROL_PLANE_JOB_WORKSPACE_PVC:-}"
workspace_mount_path="${CONTROL_PLANE_JOB_WORKSPACE_MOUNT_PATH:-${CONTROL_PLANE_WORKSPACE_MOUNT_PATH:-/workspace}}"
workspace_subpath="${CONTROL_PLANE_JOB_WORKSPACE_SUBPATH:-${CONTROL_PLANE_WORKSPACE_SUBPATH:-workspace}}"
job_service_account="${CONTROL_PLANE_JOB_SERVICE_ACCOUNT:-}"
job_image_pull_policy="${CONTROL_PLANE_JOB_IMAGE_PULL_POLICY:-IfNotPresent}"
job_cpu_request="${CONTROL_PLANE_JOB_CPU_REQUEST:-100m}"
job_cpu_limit="${CONTROL_PLANE_JOB_CPU_LIMIT:-1000m}"
job_memory_request="${CONTROL_PLANE_JOB_MEMORY_REQUEST:-128Mi}"
job_memory_limit="${CONTROL_PLANE_JOB_MEMORY_LIMIT:-1Gi}"
input_mount_path="${CONTROL_PLANE_JOB_INPUT_MOUNT_PATH:-/var/run/control-plane/job-inputs}"
job_transfer_image="${CONTROL_PLANE_JOB_TRANSFER_IMAGE:-}"
job_transfer_host="${CONTROL_PLANE_JOB_TRANSFER_HOST:-control-plane.${CONTROL_PLANE_K8S_NAMESPACE:-default}.svc.cluster.local}"
job_transfer_port="${CONTROL_PLANE_JOB_TRANSFER_PORT:-2222}"
job_transfer_user="${CONTROL_PLANE_JOB_TRANSFER_USER:-${USER:-copilot}}"
job_transfer_root="${CONTROL_PLANE_JOB_TRANSFER_ROOT:-${TMPDIR:-/tmp}/job-transfers}"
host_key_dir="${CONTROL_PLANE_HOST_KEY_DIR:-/var/lib/control-plane/ssh-host-keys}"
authorized_keys_path="${HOME:-/home/${USER:-copilot}}/.ssh/authorized_keys"
mount_files=()
created_transfer_secret=""
created_transfer_id=""
job_created=0
job_transfer_key_dir=""

cleanup() {
  if [[ "${job_created}" -eq 0 ]] && [[ -n "${created_transfer_secret}" ]]; then
    kubectl delete secret --namespace "${namespace}" "${created_transfer_secret}" --ignore-not-found >/dev/null 2>&1 || true
  fi
  if [[ "${job_created}" -eq 0 ]] && [[ -n "${created_transfer_id}" ]]; then
    control-plane-job-transfer release-access --transfer-id "${created_transfer_id}" --remove-transfer-dir >/dev/null 2>&1 || true
  fi
  if [[ -n "${job_transfer_key_dir}" ]]; then
    rm -rf "${job_transfer_key_dir}" >/dev/null 2>&1 || true
  fi
}
trap cleanup EXIT

while [[ $# -gt 0 ]]; do
  case "$1" in
    --namespace)
      namespace="$2"
      shift 2
      ;;
    --job-namespace)
      namespace="$2"
      shift 2
      ;;
    --image)
      image="$2"
      shift 2
      ;;
    --job-name)
      job_name="$2"
      shift 2
      ;;
    --mount-file)
      mount_files+=("$2")
      shift 2
      ;;
    --input-mount-path)
      input_mount_path="$2"
      shift 2
      ;;
    --help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    *)
      die "unknown option: $1"
      ;;
  esac
done

[[ -n "${image}" ]] || die "--image is required"
[[ $# -gt 0 ]] || die "a command must be provided after --"

if [[ -z "${job_name}" ]]; then
  job_name="control-plane-job-$(date +%s)"
fi

if [[ -z "${workspace_pvc}" ]] && [[ "${namespace}" == "${CONTROL_PLANE_K8S_NAMESPACE:-default}" ]]; then
  workspace_pvc="${CONTROL_PLANE_WORKSPACE_PVC:-}"
fi

command_block="$(render_yaml_list '            ' "$@")"
volume_mount_entries=""
volume_entries=""
init_container_entries=""
sidecar_entries=""
job_metadata_block=""
volume_mount_block=""
volume_block=""
init_containers_block=""
service_account_block=""
resources_block=$(cat <<EOF
          resources:
            requests:
              cpu: $(yaml_quote "${job_cpu_request}")
              memory: $(yaml_quote "${job_memory_request}")
            limits:
              cpu: $(yaml_quote "${job_cpu_limit}")
              memory: $(yaml_quote "${job_memory_limit}")
EOF
)

if [[ -n "${workspace_pvc}" ]]; then
  volume_mount_entries="$(append_yaml_block "${volume_mount_entries}" "$(cat <<EOF
            - name: workspace
              mountPath: $(yaml_quote "${workspace_mount_path}")
              subPath: $(yaml_quote "${workspace_subpath}")
EOF
  )")"
  volume_entries="$(append_yaml_block "${volume_entries}" "$(cat <<EOF
        - name: workspace
          persistentVolumeClaim:
            claimName: $(yaml_quote "${workspace_pvc}")
EOF
  )")"
fi

if [[ -n "${job_service_account}" ]]; then
  service_account_block=$(cat <<EOF
      serviceAccountName: $(yaml_quote "${job_service_account}")
EOF
  )
fi

if [[ ${#mount_files[@]} -gt 0 ]]; then
  command -v control-plane-job-transfer >/dev/null 2>&1 || die "missing control-plane-job-transfer helper"
  command -v jq >/dev/null 2>&1 || die "missing jq"
  command -v kubectl >/dev/null 2>&1 || die "missing kubectl"
  command -v ssh-keygen >/dev/null 2>&1 || die "missing ssh-keygen"
  [[ -n "${job_transfer_image}" ]] || die "CONTROL_PLANE_JOB_TRANSFER_IMAGE is required when --mount-file is used"
  [[ -n "${job_transfer_host}" ]] || die "CONTROL_PLANE_JOB_TRANSFER_HOST is required when --mount-file is used"
  [[ -n "${job_transfer_port}" ]] || die "CONTROL_PLANE_JOB_TRANSFER_PORT is required when --mount-file is used"
  [[ -n "${job_transfer_user}" ]] || die "CONTROL_PLANE_JOB_TRANSFER_USER is required when --mount-file is used"
  [[ -f "${host_key_dir}/ssh_host_ed25519_key.pub" ]] || die "missing SSH host key at ${host_key_dir}/ssh_host_ed25519_key.pub"

  created_transfer_id="$(printf '%s-%s-%s\n' "${job_name}" "$(date +%s)" "$RANDOM" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9-' '-')"
  created_transfer_id="${created_transfer_id%-}"
  created_transfer_secret="$(job_transfer_secret_name "${job_name}")"
  created_transfer_dir="${job_transfer_root%/}/${created_transfer_id}"
  authorized_key_marker="control-plane-job-transfer:${created_transfer_id}"
  job_transfer_key_dir="$(mktemp -d "${TMPDIR:-/tmp}/k8s-job-transfer.XXXXXX")"
  ssh_private_key_path="${job_transfer_key_dir}/id_ed25519"
  ssh_known_hosts_path="${job_transfer_key_dir}/known_hosts"
  manifest_path="${created_transfer_dir}/manifest.json"
  transfer_files_json='[]'
  mkdir -p "${created_transfer_dir}/input" "${created_transfer_dir}/output"
  ssh-keygen -q -t ed25519 -N '' -f "${ssh_private_key_path}" >/dev/null
  printf '[%s]:%s ' "${job_transfer_host}" "${job_transfer_port}" > "${ssh_known_hosts_path}"
  cat "${host_key_dir}/ssh_host_ed25519_key.pub" >> "${ssh_known_hosts_path}"
  append_authorized_key_block "${authorized_key_marker}" "${ssh_private_key_path}.pub"

  for mount_file in "${mount_files[@]}"; do
    normalized_mount_file="$(normalize_mount_file_spec "${mount_file}")"
    source_path="${normalized_mount_file%%$'\t'*}"
    destination_path="${normalized_mount_file#*$'\t'}"
    staged_input_path="${created_transfer_dir}/input/${destination_path}"
    mkdir -p "$(dirname "${staged_input_path}")"
    cp "${source_path}" "${staged_input_path}"
    source_sha256="$(sha256sum "${source_path}" | awk '{ print $1 }')"
    transfer_files_json="$(jq -c \
      --arg source_path "${source_path}" \
      --arg destination_path "${destination_path}" \
      --arg source_sha256 "${source_sha256}" \
      '. + [{
        source_path: $source_path,
        destination_path: $destination_path,
        source_sha256: $source_sha256
      }]' <<<"${transfer_files_json}")"
  done

  jq -n \
    --arg transfer_id "${created_transfer_id}" \
    --arg job_name "${job_name}" \
    --arg job_namespace "${namespace}" \
    --arg secret_name "${created_transfer_secret}" \
    --arg authorized_key_marker "${authorized_key_marker}" \
    --arg input_root "${created_transfer_dir}/input" \
    --arg output_root "${created_transfer_dir}/output" \
    --argjson files "${transfer_files_json}" \
    '{
      transfer_id: $transfer_id,
      job_name: $job_name,
      job_namespace: $job_namespace,
      secret_name: $secret_name,
      authorized_key_marker: $authorized_key_marker,
      input_root: $input_root,
      output_root: $output_root,
      files: $files
    }' > "${manifest_path}"

  kubectl create secret generic "${created_transfer_secret}" \
    --namespace "${namespace}" \
    --from-file=id_ed25519="${ssh_private_key_path}" \
    --from-file=known_hosts="${ssh_known_hosts_path}" \
    >/dev/null

  volume_mount_entries="$(append_yaml_block "${volume_mount_entries}" "$(cat <<EOF
            - name: job-inputs
              mountPath: $(yaml_quote "${input_mount_path}")
            - name: job-transfer-auth
              mountPath: '/var/run/control-plane-job-transfer'
              readOnly: true
EOF
  )")"

  volume_entries="$(append_yaml_block "${volume_entries}" "$(cat <<EOF
        - name: job-inputs
          emptyDir: {}
        - name: job-transfer-auth
          secret:
            secretName: $(yaml_quote "${created_transfer_secret}")
            defaultMode: 0400
EOF
  )")"

  job_metadata_block=$(cat <<EOF
  annotations:
    control-plane.github.io/job-transfer-id: $(yaml_quote "${created_transfer_id}")
    control-plane.github.io/job-transfer-secret: $(yaml_quote "${created_transfer_secret}")
EOF
  )

  init_container_entries="$(append_yaml_block "${init_container_entries}" "$(cat <<EOF
        - name: job-transfer-init
          image: $(yaml_quote "${job_transfer_image}")
          imagePullPolicy: $(yaml_quote "${job_image_pull_policy}")
          env:
            - name: CONTROL_PLANE_TRANSFER_HOST
              value: $(yaml_quote "${job_transfer_host}")
            - name: CONTROL_PLANE_TRANSFER_PORT
              value: $(yaml_quote "${job_transfer_port}")
            - name: CONTROL_PLANE_TRANSFER_USER
              value: $(yaml_quote "${job_transfer_user}")
            - name: CONTROL_PLANE_TRANSFER_REMOTE_PATH
              value: $(yaml_quote "${created_transfer_dir}/input")
            - name: CONTROL_PLANE_JOB_INPUT_MOUNT_PATH
              value: $(yaml_quote "${input_mount_path}")
          command:
            - /bin/bash
            - -lc
            - |
              set -euo pipefail
              cat > /tmp/rclone.conf <<'RCLONE'
              [control-plane]
              type = sftp
              host = \${CONTROL_PLANE_TRANSFER_HOST}
              user = \${CONTROL_PLANE_TRANSFER_USER}
              port = \${CONTROL_PLANE_TRANSFER_PORT}
              key_file = /var/run/control-plane-job-transfer/id_ed25519
              known_hosts_file = /var/run/control-plane-job-transfer/known_hosts
              shell_type = none
              RCLONE
              mkdir -p "\${CONTROL_PLANE_JOB_INPUT_MOUNT_PATH}"
              rclone --config /tmp/rclone.conf copy "control-plane:\${CONTROL_PLANE_TRANSFER_REMOTE_PATH}" "\${CONTROL_PLANE_JOB_INPUT_MOUNT_PATH}"
          volumeMounts:
            - name: job-inputs
              mountPath: $(yaml_quote "${input_mount_path}")
            - name: job-transfer-auth
              mountPath: '/var/run/control-plane-job-transfer'
              readOnly: true
EOF
  )")"

  sidecar_entries="$(append_yaml_block "${sidecar_entries}" "$(cat <<EOF
        - name: job-transfer-sync
          image: $(yaml_quote "${job_transfer_image}")
          imagePullPolicy: $(yaml_quote "${job_image_pull_policy}")
          env:
            - name: CONTROL_PLANE_TRANSFER_ID
              value: $(yaml_quote "${created_transfer_id}")
            - name: CONTROL_PLANE_TRANSFER_HOST
              value: $(yaml_quote "${job_transfer_host}")
            - name: CONTROL_PLANE_TRANSFER_PORT
              value: $(yaml_quote "${job_transfer_port}")
            - name: CONTROL_PLANE_TRANSFER_USER
              value: $(yaml_quote "${job_transfer_user}")
            - name: CONTROL_PLANE_TRANSFER_OUTPUT_PATH
              value: $(yaml_quote "${created_transfer_dir}/output")
            - name: CONTROL_PLANE_JOB_INPUT_MOUNT_PATH
              value: $(yaml_quote "${input_mount_path}")
          command:
            - /bin/bash
            - -lc
            - |
              set -euo pipefail
              api_server="https://\${KUBERNETES_SERVICE_HOST}:\${KUBERNETES_SERVICE_PORT_HTTPS:-443}"
              service_account_dir=/var/run/secrets/kubernetes.io/serviceaccount
              token="\$(cat "\${service_account_dir}/token")"
              namespace="\$(cat "\${service_account_dir}/namespace")"
              ca_crt="\${service_account_dir}/ca.crt"
              pod_name="\${HOSTNAME:?}"
              execution_exit_code=""
              while [[ -z "\${execution_exit_code}" ]]; do
                pod_json="\$(curl -fsS --cacert "\${ca_crt}" -H "Authorization: Bearer \${token}" "\${api_server}/api/v1/namespaces/\${namespace}/pods/\${pod_name}")"
                execution_exit_code="\$(jq -r '.status.containerStatuses[] | select(.name == "execution") | .state.terminated.exitCode // empty' <<<"\${pod_json}")"
                if [[ -z "\${execution_exit_code}" ]]; then
                  sleep 1
                fi
              done
              ssh_opts=(
                -i /var/run/control-plane-job-transfer/id_ed25519
                -p "\${CONTROL_PLANE_TRANSFER_PORT}"
                -o BatchMode=yes
                -o StrictHostKeyChecking=yes
                -o UserKnownHostsFile=/var/run/control-plane-job-transfer/known_hosts
              )
              cat > /tmp/rclone.conf <<'RCLONE'
              [control-plane]
              type = sftp
              host = \${CONTROL_PLANE_TRANSFER_HOST}
              user = \${CONTROL_PLANE_TRANSFER_USER}
              port = \${CONTROL_PLANE_TRANSFER_PORT}
              key_file = /var/run/control-plane-job-transfer/id_ed25519
              known_hosts_file = /var/run/control-plane-job-transfer/known_hosts
              shell_type = none
              RCLONE
              if [[ "\${execution_exit_code}" == "0" ]]; then
                rclone --config /tmp/rclone.conf copy "\${CONTROL_PLANE_JOB_INPUT_MOUNT_PATH}" "control-plane:\${CONTROL_PLANE_TRANSFER_OUTPUT_PATH}"
                ssh "\${ssh_opts[@]}" "\${CONTROL_PLANE_TRANSFER_USER}@\${CONTROL_PLANE_TRANSFER_HOST}" \
                  "control-plane-job-transfer finalize --transfer-id \${CONTROL_PLANE_TRANSFER_ID}"
                exit 0
              fi
              ssh "\${ssh_opts[@]}" "\${CONTROL_PLANE_TRANSFER_USER}@\${CONTROL_PLANE_TRANSFER_HOST}" \
                "control-plane-job-transfer release-access --transfer-id \${CONTROL_PLANE_TRANSFER_ID}"
              exit "\${execution_exit_code}"
          volumeMounts:
            - name: job-inputs
              mountPath: $(yaml_quote "${input_mount_path}")
            - name: job-transfer-auth
              mountPath: '/var/run/control-plane-job-transfer'
              readOnly: true
EOF
  )")"
fi

if [[ -n "${volume_mount_entries}" ]]; then
  volume_mount_block=$(cat <<EOF
          volumeMounts:
${volume_mount_entries}
EOF
  )
fi

if [[ -n "${volume_entries}" ]]; then
  volume_block=$(cat <<EOF
      volumes:
${volume_entries}
EOF
  )
fi

if [[ -n "${init_container_entries}" ]]; then
  init_containers_block=$(cat <<EOF
      initContainers:
${init_container_entries}
EOF
  )
fi

if [[ -n "${sidecar_entries}" ]]; then
  container_entries=$(cat <<EOF
        - name: execution
          image: $(yaml_quote "${image}")
          imagePullPolicy: $(yaml_quote "${job_image_pull_policy}")
          command:
${command_block}
${resources_block}
${volume_mount_block}
${sidecar_entries}
EOF
  )
else
  container_entries=$(cat <<EOF
        - name: execution
          image: $(yaml_quote "${image}")
          imagePullPolicy: $(yaml_quote "${job_image_pull_policy}")
          command:
${command_block}
${resources_block}
${volume_mount_block}
EOF
  )
fi

cat <<EOF | kubectl create -f - >/dev/null
apiVersion: batch/v1
kind: Job
metadata:
  name: $(yaml_quote "${job_name}")
  namespace: $(yaml_quote "${namespace}")
${job_metadata_block}
spec:
  backoffLimit: 0
  template:
    metadata:
      labels:
        app.kubernetes.io/name: control-plane-execution
        job-name: $(yaml_quote "${job_name}")
    spec:
      restartPolicy: Never
${service_account_block}
${init_containers_block}
      containers:
${container_entries}
${volume_block}
EOF

job_created=1
trap - EXIT

printf '%s\n' "${job_name}"
