#!/usr/bin/env bash
set -euo pipefail

runtime_config_file="${CONTROL_PLANE_RUNTIME_ENV_FILE:-${HOME:-/home/${USER:-copilot}}/.config/control-plane/runtime.env}"
if [[ -f "${runtime_config_file}" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "${runtime_config_file}"
  set +a
fi

runtime_tool_bin="${CONTROL_PLANE_RUNTIME_TOOL_BIN:-/usr/local/bin/control-plane-runtime-tool}"
exec "${runtime_tool_bin}" control-plane-session-exec "$@"
