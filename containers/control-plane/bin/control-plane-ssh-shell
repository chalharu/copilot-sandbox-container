#!/usr/bin/env bash
set -euo pipefail

runtime_config_file="${CONTROL_PLANE_RUNTIME_ENV_FILE:-${HOME:-/home/${USER:-copilot}}/.config/control-plane/runtime.env}"
if [[ -f "${runtime_config_file}" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "${runtime_config_file}"
  set +a
fi

: "${LANG:=C.UTF-8}"
: "${LC_CTYPE:=C.UTF-8}"
export LANG LC_CTYPE

debug_log="${CONTROL_PLANE_SSH_SHELL_LOG:-}"

debug_log_line() {
  [[ -n "${debug_log}" ]] || return 0
  printf '%s\n' "$1" >> "${debug_log}"
}

run_login_shell() {
  local stdin_tty="no"
  local stdout_tty="no"

  if [[ -t 0 ]]; then
    stdin_tty="yes"
  fi
  if [[ -t 1 ]]; then
    stdout_tty="yes"
  fi
  debug_log_line \
    "mode=login argv0=${0} ssh_tty=${SSH_TTY:-} sty=${STY:-} stdin_tty=${stdin_tty} stdout_tty=${stdout_tty}"
  if [[ -n "${SSH_TTY:-}" ]] \
    && [[ -z "${STY:-}" ]] \
    && [[ -t 0 ]] \
    && [[ -t 1 ]] \
    && command -v control-plane-session >/dev/null 2>&1; then
    debug_log_line "mode=login action=copilot-session"
    exec control-plane-session
  fi

  debug_log_line "mode=login action=bash-il"
  exec /bin/bash -il
}

if [[ "${1:-}" == "-c" ]]; then
  shift
  [[ $# -gt 0 ]] || {
    printf 'control-plane-ssh-shell: missing command for -c\n' >&2
    exit 64
  }
  debug_log_line "mode=command command=$1"
  exec /bin/bash -c "$1"
fi

run_login_shell
