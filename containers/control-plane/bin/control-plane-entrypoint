#!/usr/bin/env bash
set -euo pipefail

control_plane_user="${CONTROL_PLANE_USER:-copilot}"
control_plane_uid="$(id -u "${control_plane_user}")"
control_plane_home="$(getent passwd "${control_plane_user}" | cut -d: -f6)"
control_plane_workspace="${CONTROL_PLANE_WORKSPACE:-/workspace}"
containers_config_dir="${control_plane_home}/.config/containers"
containers_storage_config_path="${containers_config_dir}/storage.conf"
containers_engine_config_path="${containers_config_dir}/containers.conf"
podman_state_root="${control_plane_home}/.copilot/containers"
runtime_dir="${XDG_RUNTIME_DIR:-/run/user/${control_plane_uid}}"
tmp_dir="${TMPDIR:-/tmp/control-plane-${control_plane_uid}}"
screen_dir="${SCREENDIR:-${runtime_dir}/screen}"
host_key_dir="${CONTROL_PLANE_HOST_KEY_DIR:-/var/lib/control-plane/ssh-host-keys}"
bundled_skills_dir="/usr/local/share/control-plane/skills"
copilot_skills_dir="${control_plane_home}/.copilot/skills"
authorized_keys_path="${control_plane_home}/.ssh/authorized_keys"
kube_dir="${control_plane_home}/.kube"
kubeconfig_path="${kube_dir}/config"
service_account_dir="/var/run/secrets/kubernetes.io/serviceaccount"
runtime_config_dir="${control_plane_home}/.config/control-plane"
runtime_config_path="${runtime_config_dir}/runtime.env"
copilot_token_path="${runtime_config_dir}/copilot-github-token"
dockerhub_username_path="${runtime_config_dir}/dockerhub-username"
dockerhub_token_path="${runtime_config_dir}/dockerhub-token"
git_config_path="${control_plane_home}/.gitconfig"
copilot_github_token="${COPILOT_GITHUB_TOKEN:-}"
dockerhub_username="${DOCKERHUB_USERNAME:-}"
dockerhub_token="${DOCKERHUB_TOKEN:-}"
git_user_name="${CONTROL_PLANE_GIT_USER_NAME:-}"
git_user_email="${CONTROL_PLANE_GIT_USER_EMAIL:-}"
podman_storage_driver="${CONTROL_PLANE_PODMAN_STORAGE_DRIVER:-}"
local_podman_mode="${CONTROL_PLANE_LOCAL_PODMAN_MODE:-rootless}"
rootful_podman_storage_driver="${CONTROL_PLANE_ROOTFUL_PODMAN_STORAGE_DRIVER:-vfs}"
rootful_podman_runtime_dir="${CONTROL_PLANE_ROOTFUL_PODMAN_RUNTIME_DIR:-/run/control-plane}"
rootful_podman_socket="${CONTROL_PLANE_ROOTFUL_PODMAN_SOCKET:-${rootful_podman_runtime_dir}/podman-root.sock}"
rootful_podman_state_root="${CONTROL_PLANE_ROOTFUL_PODMAN_STATE_ROOT:-${podman_state_root}/rootful-${rootful_podman_storage_driver}}"
rootful_podman_graphroot="${rootful_podman_state_root}/storage"
rootful_podman_runroot="${rootful_podman_runtime_dir}/runroot"
rootful_podman_storage_config_path="${rootful_podman_runtime_dir}/storage.conf"
rootful_podman_log_path="${rootful_podman_runtime_dir}/podman-root.log"
rootful_podman_default_cgroups="${CONTROL_PLANE_ROOTFUL_PODMAN_DEFAULT_CGROUPS:-disabled}"
rootful_podman_default_network="${CONTROL_PLANE_ROOTFUL_PODMAN_DEFAULT_NETWORK:-host}"
rootful_podman_build_isolation="${CONTROL_PLANE_ROOTFUL_PODMAN_BUILD_ISOLATION:-chroot}"
podman_bin="${CONTROL_PLANE_PODMAN_BIN:-/usr/bin/podman}"
job_namespace="${CONTROL_PLANE_JOB_NAMESPACE:-${CONTROL_PLANE_K8S_NAMESPACE:-default}}"
job_workspace_pvc="${CONTROL_PLANE_JOB_WORKSPACE_PVC:-}"
job_workspace_mount_path="${CONTROL_PLANE_JOB_WORKSPACE_MOUNT_PATH:-${CONTROL_PLANE_WORKSPACE_MOUNT_PATH:-/workspace}}"
job_workspace_subpath="${CONTROL_PLANE_JOB_WORKSPACE_SUBPATH:-${CONTROL_PLANE_WORKSPACE_SUBPATH:-workspace}}"
job_input_mount_path="${CONTROL_PLANE_JOB_INPUT_MOUNT_PATH:-/var/run/control-plane/job-inputs}"

if [[ -z "${podman_storage_driver}" ]]; then
  if [[ -e /dev/fuse ]]; then
    podman_storage_driver="overlay"
  else
    podman_storage_driver="vfs"
  fi
fi

case "${podman_storage_driver}" in
  overlay|vfs)
    ;;
  *)
    printf 'Unsupported CONTROL_PLANE_PODMAN_STORAGE_DRIVER: %s\n' "${podman_storage_driver}" >&2
    exit 1
    ;;
esac

case "${local_podman_mode}" in
  rootless|rootful-service)
    ;;
  *)
    printf 'Unsupported CONTROL_PLANE_LOCAL_PODMAN_MODE: %s\n' "${local_podman_mode}" >&2
    exit 1
    ;;
esac

case "${rootful_podman_storage_driver}" in
  overlay|vfs)
    ;;
  *)
    printf 'Unsupported CONTROL_PLANE_ROOTFUL_PODMAN_STORAGE_DRIVER: %s\n' "${rootful_podman_storage_driver}" >&2
    exit 1
    ;;
esac

podman_state_dir="${podman_state_root}/${podman_storage_driver}"
podman_graphroot="${podman_state_dir}/storage"
podman_runroot="${runtime_dir}/${podman_storage_driver}/containers/storage"

write_runtime_var() {
  printf '%s=%q\n' "$1" "$2"
}

write_storage_conf() {
  {
    printf '%s\n' '[storage]'
    printf 'driver = "%s"\n' "${podman_storage_driver}"
    printf 'graphroot = "%s"\n' "${podman_graphroot}"
    printf 'runroot = "%s"\n' "${podman_runroot}"
    if [[ "${podman_storage_driver}" == "overlay" ]]; then
      printf '\n%s\n' '[storage.options]'
      printf '%s\n' 'mount_program = "/usr/bin/fuse-overlayfs"'
    fi
  } > "${containers_storage_config_path}"
}

write_containers_conf() {
  cat > "${containers_engine_config_path}" <<'EOF'
[engine]
cgroup_manager = "cgroupfs"
events_logger = "file"
EOF
}

write_rootful_storage_conf() {
  {
    printf '%s\n' '[storage]'
    printf 'driver = "%s"\n' "${rootful_podman_storage_driver}"
    printf 'graphroot = "%s"\n' "${rootful_podman_graphroot}"
    printf 'runroot = "%s"\n' "${rootful_podman_runroot}"
    if [[ "${rootful_podman_storage_driver}" == "overlay" ]]; then
      printf '\n%s\n' '[storage.options]'
      printf '%s\n' 'mount_program = "/usr/bin/fuse-overlayfs"'
    fi
  } > "${rootful_podman_storage_config_path}"
}

safe_chown_tree() {
  local owner="$1"
  shift
  local target
  for target in "$@"; do
    [[ -e "${target}" ]] || continue
    find "${target}" \( -type l -o -type s \) -prune -o -exec chown "${owner}" {} +
  done
}

directory_has_entries() {
  local target="$1"
  find "${target}" -mindepth 1 -maxdepth 1 -print -quit | grep -q .
}

capability_bit() {
  case "$1" in
    CHOWN) printf '0\n' ;;
    DAC_OVERRIDE) printf '1\n' ;;
    FOWNER) printf '3\n' ;;
    KILL) printf '5\n' ;;
    SETGID) printf '6\n' ;;
    SETPCAP) printf '8\n' ;;
    SETUID) printf '7\n' ;;
    NET_ADMIN) printf '12\n' ;;
    SYS_CHROOT) printf '18\n' ;;
    SYS_ADMIN) printf '21\n' ;;
    MKNOD) printf '27\n' ;;
    SETFCAP) printf '31\n' ;;
    *)
      printf 'Unsupported capability name: %s\n' "$1" >&2
      exit 1
      ;;
  esac
}

has_effective_capability() {
  local capability_name="$1"
  local capability_mask="$2"
  local bit

  bit="$(capability_bit "${capability_name}")"
  (( (16#${capability_mask} & (1 << bit)) != 0 ))
}

require_container_capabilities() {
  local capability_mask
  local missing=()
  local capability_name

  [[ "$(id -u)" -eq 0 ]] || return 0
  capability_mask="$(awk '/^CapEff:/ { print $2 }' /proc/self/status)"
  [[ -n "${capability_mask}" ]] || return 0

  for capability_name in CHOWN DAC_OVERRIDE FOWNER SETGID SETUID SYS_CHROOT; do
    if ! has_effective_capability "${capability_name}" "${capability_mask}"; then
      missing+=("${capability_name}")
    fi
  done

  if [[ "${local_podman_mode}" == "rootful-service" ]]; then
    for capability_name in KILL MKNOD NET_ADMIN SETFCAP SETPCAP SYS_ADMIN; do
      if ! has_effective_capability "${capability_name}" "${capability_mask}"; then
        missing+=("${capability_name}")
      fi
    done
  fi

  if [[ ${#missing[@]} -gt 0 ]]; then
    printf 'Missing Linux capabilities for control-plane startup: %s\n' "${missing[*]}" >&2
    printf '%s\n' \
      'Keep drop: ALL only when you re-add CHOWN,DAC_OVERRIDE,FOWNER,SETGID,SETUID,SYS_CHROOT, or run the container privileged.' \
      'When CONTROL_PLANE_LOCAL_PODMAN_MODE=rootful-service, also re-add KILL,MKNOD,NET_ADMIN,SETFCAP,SETPCAP,SYS_ADMIN so the nested Podman service can launch containers on clusters that block Pod user namespaces.' \
      'SSH requires SETUID/SETGID plus SYS_CHROOT for privilege separation, and the entrypoint still needs ownership-related capabilities on mounted state.' \
      >&2
    exit 1
  fi
}

detect_legacy_podman_storage_driver() {
  local legacy_state_root="$1"
  local storage_root="${legacy_state_root}/storage"

  if [[ ! -d "${storage_root}" ]]; then
    return 1
  fi

  if [[ -d "${storage_root}/overlay" ]] || compgen -G "${storage_root}/overlay-*" >/dev/null; then
    printf 'overlay\n'
    return 0
  fi

  if [[ -d "${storage_root}/vfs" ]] || compgen -G "${storage_root}/vfs-*" >/dev/null; then
    printf 'vfs\n'
    return 0
  fi

  return 1
}

migrate_legacy_podman_state() {
  local legacy_state_root="$1"
  local detected_driver

  [[ -d "${legacy_state_root}/storage" ]] || return 0
  [[ ! -e "${podman_graphroot}" ]] || return 0

  detected_driver="$(detect_legacy_podman_storage_driver "${legacy_state_root}" || true)"
  if [[ -z "${detected_driver}" ]] || [[ "${detected_driver}" != "${podman_storage_driver}" ]]; then
    return 0
  fi

  mkdir -p "${podman_state_dir}"
  mv "${legacy_state_root}/storage" "${podman_graphroot}"
}

write_private_file() {
  local target_path="$1"
  local content="$2"
  local owner="$3"

  if [[ -z "${content}" ]]; then
    rm -f "${target_path}"
    return
  fi

  (
    umask 077
    printf '%s' "${content}" > "${target_path}"
  )
  chown "${owner}" "${target_path}"
  chmod 600 "${target_path}"
}

start_rootful_podman_service() {
  local service_pid
  local wait_count=0

  [[ "${local_podman_mode}" == "rootful-service" ]] || return 0

  mkdir -p "${rootful_podman_runtime_dir}" "${rootful_podman_graphroot}" "${rootful_podman_runroot}"
  chmod 755 "${rootful_podman_runtime_dir}"
  write_rootful_storage_conf
  rm -f "${rootful_podman_socket}"

  env -u CONTAINER_HOST -u DOCKER_HOST -u _CONTAINERS_USERNS_CONFIGURED \
    XDG_RUNTIME_DIR="${rootful_podman_runtime_dir}" \
    CONTAINERS_STORAGE_CONF="${rootful_podman_storage_config_path}" \
    "${podman_bin}" \
      --storage-driver "${rootful_podman_storage_driver}" \
      --root "${rootful_podman_graphroot}" \
      --runroot "${rootful_podman_runroot}" \
      system service --time=0 "unix://${rootful_podman_socket}" \
      > "${rootful_podman_log_path}" 2>&1 &
  service_pid=$!

  while [[ ! -S "${rootful_podman_socket}" ]]; do
    if ! kill -0 "${service_pid}" 2>/dev/null; then
      printf 'control-plane-entrypoint: failed to start rootful Podman service.\n' >&2
      cat "${rootful_podman_log_path}" >&2 || true
      exit 1
    fi
    wait_count=$((wait_count + 1))
    if [[ "${wait_count}" -ge 100 ]]; then
      printf 'control-plane-entrypoint: timed out waiting for rootful Podman socket %s\n' "${rootful_podman_socket}" >&2
      cat "${rootful_podman_log_path}" >&2 || true
      exit 1
    fi
    sleep 0.1
  done

  chown "${control_plane_user}:${control_plane_user}" "${rootful_podman_socket}"
  chmod 660 "${rootful_podman_socket}"
}

ensure_podman_storage_link() {
  local link_path="$1"
  local state_path="$2"
  local entries=()

  mkdir -p "${state_path}"

  if [[ -L "${link_path}" ]]; then
    if [[ "$(readlink "${link_path}")" == "${state_path}" ]]; then
      return
    fi

    rm -f "${link_path}"
    ln -s "${state_path}" "${link_path}"
    return
  fi

  if [[ -e "${link_path}" ]] && [[ ! -d "${link_path}" ]]; then
    printf 'Refusing to replace non-directory path at %s\n' "${link_path}" >&2
    exit 1
  fi

  if [[ -d "${link_path}" ]] && directory_has_entries "${link_path}"; then
    if directory_has_entries "${state_path}"; then
      printf 'Refusing to overwrite existing Podman storage; migrate %s into %s manually\n' "${link_path}" "${state_path}" >&2
      exit 1
    fi

    shopt -s dotglob nullglob
    entries=("${link_path}"/*)
    shopt -u dotglob nullglob
    if [[ ${#entries[@]} -gt 0 ]]; then
      mv -n "${entries[@]}" "${state_path}/"
      if directory_has_entries "${link_path}"; then
        printf 'Refusing to continue after partial Podman storage migration from %s into %s\n' "${link_path}" "${state_path}" >&2
        exit 1
      fi
    fi
  fi

  rm -rf "${link_path}"
  ln -s "${state_path}" "${link_path}"
}

ensure_ssh_host_key() {
  local key_type="$1"
  local key_basename="$2"
  local persistent_key_path="${host_key_dir}/${key_basename}"
  local etc_key_path="/etc/ssh/${key_basename}"

  if [[ -e "${persistent_key_path}" ]] && [[ ! -f "${persistent_key_path}" ]]; then
    printf 'Refusing to use non-file SSH host key path at %s\n' "${persistent_key_path}" >&2
    exit 1
  fi

  if [[ ! -f "${persistent_key_path}" ]]; then
    ssh-keygen -q -N '' -t "${key_type}" -f "${persistent_key_path}"
  fi

  if [[ ! -f "${persistent_key_path}.pub" ]]; then
    ssh-keygen -y -f "${persistent_key_path}" > "${persistent_key_path}.pub"
  fi

  chown root:root "${persistent_key_path}" "${persistent_key_path}.pub"
  chmod 600 "${persistent_key_path}"
  chmod 644 "${persistent_key_path}.pub"

  ln -sfn "${persistent_key_path}" "${etc_key_path}"
  ln -sfn "${persistent_key_path}.pub" "${etc_key_path}.pub"
}

install_bundled_control_plane_skill() {
  local skill_name="control-plane-operations"
  local source_dir="${bundled_skills_dir}/${skill_name}"
  local target_dir="${copilot_skills_dir}/${skill_name}"

  [[ -d "${source_dir}" ]] || return 0

  mkdir -p "${copilot_skills_dir}"
  rm -rf "${target_dir}"
  mkdir -p "${target_dir}"
  cp -R "${source_dir}/." "${target_dir}/"
  find "${target_dir}" -type d -exec chmod 755 {} +
  find "${target_dir}" -type f -exec chmod 644 {} +
  safe_chown_tree "${control_plane_user}:${control_plane_user}" "${target_dir}"
}

configure_git_credential_helper() {
  local hostname="$1"
  local helper_key="credential.https://${hostname}.helper"
  local gh_bin="$2"

  git config --file "${git_config_path}" --replace-all "${helper_key}" ""
  git config --file "${git_config_path}" --add "${helper_key}" "!${gh_bin} auth git-credential"
}

configure_git() {
  local gh_bin

  if [[ -e "${git_config_path}" ]] && [[ ! -f "${git_config_path}" ]]; then
    printf 'Refusing to use non-file git config path at %s\n' "${git_config_path}" >&2
    exit 1
  fi

  touch "${git_config_path}"
  gh_bin="$(command -v gh)"

  if [[ -n "${git_user_name}" ]]; then
    git config --file "${git_config_path}" --replace-all user.name "${git_user_name}"
  fi

  if [[ -n "${git_user_email}" ]]; then
    git config --file "${git_config_path}" --replace-all user.email "${git_user_email}"
  fi

  configure_git_credential_helper github.com "${gh_bin}"
  configure_git_credential_helper gist.github.com "${gh_bin}"

  chown "${control_plane_user}:${control_plane_user}" "${git_config_path}"
  chmod 600 "${git_config_path}"
}

require_container_capabilities

mkdir -p \
  "${control_plane_home}/.copilot" \
  "${containers_config_dir}" \
  "${control_plane_home}/.config/gh" \
  "${control_plane_home}/.local/share" \
  "${runtime_config_dir}" \
  "${kube_dir}" \
  "${control_plane_home}/.ssh" \
  "${copilot_skills_dir}" \
  "${control_plane_workspace}" \
  "${podman_state_root}" \
  "${podman_state_dir}" \
  "${screen_dir}" \
  "${tmp_dir}" \
  "${host_key_dir}" \
  "/run/user/${control_plane_uid}" \
  "${rootful_podman_runtime_dir}" \
  /run/sshd \
  "${runtime_dir}"
migrate_legacy_podman_state "${podman_state_root}"

mkdir -p \
  "${podman_graphroot}" \
  "${podman_graphroot}/${podman_storage_driver}" \
  "${podman_graphroot}/volumes" \
  "${podman_runroot}"

safe_chown_tree "${control_plane_user}:${control_plane_user}" \
  "${control_plane_home}/.copilot" \
  "${control_plane_home}/.config" \
  "${runtime_config_dir}" \
  "${kube_dir}" \
  "${control_plane_home}/.ssh" \
  "${copilot_skills_dir}" \
  "${control_plane_workspace}" \
  "${podman_state_root}" \
  "${screen_dir}" \
  "${tmp_dir}" \
  "${runtime_dir}"
chown "${control_plane_user}:${control_plane_user}" \
  "/run/user/${control_plane_uid}" \
  "${control_plane_home}" \
  "${control_plane_home}/.local" \
  "${control_plane_home}/.local/share"

ensure_podman_storage_link "${control_plane_home}/.local/share/containers" "${podman_state_dir}"

chown -h "${control_plane_user}:${control_plane_user}" "${control_plane_home}/.local/share/containers"
chown root:root "${host_key_dir}"
chown root:root /run/sshd
chmod 755 "${control_plane_home}"
chmod 700 "${control_plane_home}/.ssh" "${runtime_dir}" "${tmp_dir}" "${screen_dir}" "${host_key_dir}"
chmod 755 /run/sshd
export XDG_RUNTIME_DIR="${runtime_dir}"
export TMPDIR="${tmp_dir}"
export SCREENDIR="${screen_dir}"
touch "${authorized_keys_path}"
chmod 600 "${authorized_keys_path}"
chown "${control_plane_user}:${control_plane_user}" "${authorized_keys_path}"

if [[ -n "${SSH_PUBLIC_KEY:-}" ]] && ! grep -Fxq "${SSH_PUBLIC_KEY}" "${authorized_keys_path}"; then
  printf '%s\n' "${SSH_PUBLIC_KEY}" >> "${authorized_keys_path}"
fi

if [[ -n "${SSH_PUBLIC_KEY_FILE:-}" ]] && [[ -f "${SSH_PUBLIC_KEY_FILE}" ]]; then
  while IFS= read -r key; do
    [[ -z "${key}" ]] && continue
    if ! grep -Fxq "${key}" "${authorized_keys_path}"; then
      printf '%s\n' "${key}" >> "${authorized_keys_path}"
    fi
  done < "${SSH_PUBLIC_KEY_FILE}"
fi

if [[ -z "${copilot_github_token}" ]] && [[ -n "${COPILOT_GITHUB_TOKEN_FILE:-}" ]] && [[ -f "${COPILOT_GITHUB_TOKEN_FILE}" ]]; then
  IFS= read -r copilot_github_token < "${COPILOT_GITHUB_TOKEN_FILE}" || true
fi

if [[ -z "${dockerhub_username}" ]] && [[ -n "${DOCKERHUB_USERNAME_FILE:-}" ]] && [[ -f "${DOCKERHUB_USERNAME_FILE}" ]]; then
  IFS= read -r dockerhub_username < "${DOCKERHUB_USERNAME_FILE}" || true
fi

if [[ -z "${dockerhub_token}" ]] && [[ -n "${DOCKERHUB_TOKEN_FILE:-}" ]] && [[ -f "${DOCKERHUB_TOKEN_FILE}" ]]; then
  IFS= read -r dockerhub_token < "${DOCKERHUB_TOKEN_FILE}" || true
fi

write_private_file "${copilot_token_path}" "${copilot_github_token}" "${control_plane_user}:${control_plane_user}"
write_private_file "${dockerhub_username_path}" "${dockerhub_username}" "${control_plane_user}:${control_plane_user}"
write_private_file "${dockerhub_token_path}" "${dockerhub_token}" "${control_plane_user}:${control_plane_user}"

if [[ -z "${KUBECONFIG:-}" ]] \
  && [[ -n "${KUBERNETES_SERVICE_HOST:-}" ]] \
  && [[ -f "${service_account_dir}/token" ]] \
  && [[ -f "${service_account_dir}/ca.crt" ]] \
  && [[ ! -f "${kubeconfig_path}" ]]; then
  namespace="default"
  if [[ -f "${service_account_dir}/namespace" ]]; then
    namespace="$(cat "${service_account_dir}/namespace")"
  fi
  cat > "${kubeconfig_path}" <<EOF
apiVersion: v1
kind: Config
clusters:
  - cluster:
      certificate-authority: ${service_account_dir}/ca.crt
      server: https://${KUBERNETES_SERVICE_HOST}:${KUBERNETES_SERVICE_PORT_HTTPS:-443}
    name: in-cluster
contexts:
  - context:
      cluster: in-cluster
      namespace: ${namespace}
      user: ${control_plane_user}
    name: in-cluster
current-context: in-cluster
users:
  - name: ${control_plane_user}
    user:
      tokenFile: ${service_account_dir}/token
EOF
  chown "${control_plane_user}:${control_plane_user}" "${kubeconfig_path}"
  chmod 600 "${kubeconfig_path}"
  export KUBECONFIG="${kubeconfig_path}"
fi

{
  write_runtime_var CONTROL_PLANE_K8S_NAMESPACE "${CONTROL_PLANE_K8S_NAMESPACE:-default}"
  write_runtime_var CONTROL_PLANE_JOB_NAMESPACE "${job_namespace}"
  write_runtime_var CONTROL_PLANE_WORKSPACE "${CONTROL_PLANE_WORKSPACE:-/workspace}"
  write_runtime_var CONTROL_PLANE_WORKSPACE_PVC "${CONTROL_PLANE_WORKSPACE_PVC:-}"
  write_runtime_var CONTROL_PLANE_WORKSPACE_MOUNT_PATH "${CONTROL_PLANE_WORKSPACE_MOUNT_PATH:-/workspace}"
  write_runtime_var CONTROL_PLANE_WORKSPACE_SUBPATH "${CONTROL_PLANE_WORKSPACE_SUBPATH:-workspace}"
  write_runtime_var CONTROL_PLANE_JOB_WORKSPACE_PVC "${job_workspace_pvc}"
  write_runtime_var CONTROL_PLANE_JOB_WORKSPACE_MOUNT_PATH "${job_workspace_mount_path}"
  write_runtime_var CONTROL_PLANE_JOB_WORKSPACE_SUBPATH "${job_workspace_subpath}"
  write_runtime_var CONTROL_PLANE_JOB_INPUT_MOUNT_PATH "${job_input_mount_path}"
  write_runtime_var CONTROL_PLANE_HOST_KEY_DIR "${host_key_dir}"
  if [[ -n "${CONTROL_PLANE_SCREEN_SESSION:-}" ]]; then
    write_runtime_var CONTROL_PLANE_SCREEN_SESSION "${CONTROL_PLANE_SCREEN_SESSION}"
  fi
  if [[ -n "${CONTROL_PLANE_COPILOT_SESSION:-}" ]]; then
    write_runtime_var CONTROL_PLANE_COPILOT_SESSION "${CONTROL_PLANE_COPILOT_SESSION}"
  fi
  if [[ -n "${CONTROL_PLANE_SESSION_SELECTION:-}" ]]; then
    write_runtime_var CONTROL_PLANE_SESSION_SELECTION "${CONTROL_PLANE_SESSION_SELECTION}"
  fi
  if [[ -n "${CONTROL_PLANE_DISABLE_SESSION_PICKER:-}" ]]; then
    write_runtime_var CONTROL_PLANE_DISABLE_SESSION_PICKER "${CONTROL_PLANE_DISABLE_SESSION_PICKER}"
  fi
  if [[ -n "${CONTROL_PLANE_RUN_MODE:-}" ]]; then
    write_runtime_var CONTROL_PLANE_RUN_MODE "${CONTROL_PLANE_RUN_MODE}"
  fi
  write_runtime_var CONTROL_PLANE_LOCAL_PODMAN_MODE "${local_podman_mode}"
  if [[ -n "${CONTROL_PLANE_EXECUTION_HINT:-}" ]]; then
    write_runtime_var CONTROL_PLANE_EXECUTION_HINT "${CONTROL_PLANE_EXECUTION_HINT}"
  fi
  write_runtime_var CONTROL_PLANE_COPILOT_WORKSPACE "${CONTROL_PLANE_COPILOT_WORKSPACE:-${CONTROL_PLANE_WORKSPACE:-/workspace}}"
  if [[ -n "${CONTROL_PLANE_COPILOT_BIN:-}" ]]; then
    write_runtime_var CONTROL_PLANE_COPILOT_BIN "${CONTROL_PLANE_COPILOT_BIN}"
  fi
  write_runtime_var CONTROL_PLANE_JOB_SERVICE_ACCOUNT "${CONTROL_PLANE_JOB_SERVICE_ACCOUNT:-}"
  write_runtime_var CONTROL_PLANE_JOB_IMAGE_PULL_POLICY "${CONTROL_PLANE_JOB_IMAGE_PULL_POLICY:-IfNotPresent}"
  write_runtime_var CONTROL_PLANE_JOB_CPU_REQUEST "${CONTROL_PLANE_JOB_CPU_REQUEST:-100m}"
  write_runtime_var CONTROL_PLANE_JOB_CPU_LIMIT "${CONTROL_PLANE_JOB_CPU_LIMIT:-1000m}"
  write_runtime_var CONTROL_PLANE_JOB_MEMORY_REQUEST "${CONTROL_PLANE_JOB_MEMORY_REQUEST:-128Mi}"
  write_runtime_var CONTROL_PLANE_JOB_MEMORY_LIMIT "${CONTROL_PLANE_JOB_MEMORY_LIMIT:-1Gi}"
  write_runtime_var XDG_RUNTIME_DIR "${runtime_dir}"
  write_runtime_var TMPDIR "${tmp_dir}"
  write_runtime_var SCREENDIR "${screen_dir}"
  if [[ "${local_podman_mode}" == "rootful-service" ]]; then
    write_runtime_var CONTAINER_HOST "unix://${rootful_podman_socket}"
    write_runtime_var DOCKER_HOST "unix://${rootful_podman_socket}"
    write_runtime_var CONTROL_PLANE_PODMAN_DEFAULT_CGROUPS "${rootful_podman_default_cgroups}"
    write_runtime_var CONTROL_PLANE_PODMAN_DEFAULT_NETWORK "${rootful_podman_default_network}"
    write_runtime_var CONTROL_PLANE_PODMAN_BUILD_ISOLATION "${rootful_podman_build_isolation}"
  fi
  write_runtime_var KUBECONFIG "${KUBECONFIG:-}"
  if [[ -n "${copilot_github_token}" ]]; then
    write_runtime_var CONTROL_PLANE_COPILOT_GITHUB_TOKEN_FILE "${copilot_token_path}"
  fi
  if [[ -n "${dockerhub_username}" ]]; then
    write_runtime_var DOCKERHUB_USERNAME_FILE "${dockerhub_username_path}"
  fi
  if [[ -n "${dockerhub_token}" ]]; then
    write_runtime_var DOCKERHUB_TOKEN_FILE "${dockerhub_token_path}"
  fi
} > "${runtime_config_path}"
chown "${control_plane_user}:${control_plane_user}" "${runtime_config_path}"
chmod 600 "${runtime_config_path}"

write_storage_conf
write_containers_conf
chown "${control_plane_user}:${control_plane_user}" "${containers_storage_config_path}"
chmod 644 "${containers_storage_config_path}"
chown "${control_plane_user}:${control_plane_user}" "${containers_engine_config_path}"
chmod 644 "${containers_engine_config_path}"

install_bundled_control_plane_skill
configure_git
ensure_ssh_host_key rsa ssh_host_rsa_key
ensure_ssh_host_key ecdsa ssh_host_ecdsa_key
ensure_ssh_host_key ed25519 ssh_host_ed25519_key
start_rootful_podman_service

if [[ $# -eq 0 ]]; then
  set -- /usr/sbin/sshd -D -e -f /etc/ssh/sshd_config
fi

exec "$@"
