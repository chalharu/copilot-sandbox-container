#!/usr/bin/env bash
set -euo pipefail

control_plane_user="${CONTROL_PLANE_USER:-copilot}"
control_plane_uid="$(id -u "${control_plane_user}")"
control_plane_home="$(getent passwd "${control_plane_user}" | cut -d: -f6)"
control_plane_workspace="${CONTROL_PLANE_WORKSPACE:-/workspace}"
copilot_state_dir="${control_plane_home}/.copilot"
copilot_config_path="${copilot_state_dir}/config.json"
copilot_command_history_state_path="${copilot_state_dir}/command-history-state.json"
copilot_session_state_dir="${copilot_state_dir}/session-state"
audit_log_db_path="${copilot_session_state_dir}/audit/audit-log.db"
audit_log_db_dir="$(dirname "${audit_log_db_path}")"
gh_config_dir="${control_plane_home}/.config/gh"
gh_hosts_path="${gh_config_dir}/hosts.yml"
runtime_dir="${XDG_RUNTIME_DIR:-/run/user/${control_plane_uid}}"
tmp_root="${CONTROL_PLANE_TMP_ROOT:-/var/tmp/control-plane}"
hook_tmp_root="${CONTROL_PLANE_HOOK_TMP_ROOT:-${tmp_root}/hooks}"
tmp_dir="${TMPDIR:-${tmp_root}/tmp-${control_plane_uid}}"
node_compile_cache_dir="${CONTROL_PLANE_NODE_COMPILE_CACHE_DIR:-${hook_tmp_root}/node-compile-cache}"
npm_cache_dir="${CONTROL_PLANE_NPM_CACHE_DIR:-${hook_tmp_root}/npm-cache}"
screen_dir="${SCREENDIR:-${runtime_dir}/screen}"
cargo_home_dir="${CARGO_HOME:-${control_plane_home}/.cargo}"
cargo_target_dir="${CARGO_TARGET_DIR:-${tmp_root}/cargo-target}"
rustup_home_dir="${RUSTUP_HOME:-/usr/local/rustup}"
host_key_dir="${CONTROL_PLANE_HOST_KEY_DIR:-/var/lib/control-plane/ssh-host-keys}"
bundled_skills_dir="/usr/local/share/control-plane/skills"
copilot_skills_dir="${copilot_state_dir}/skills"
bundled_hooks_dir="/usr/local/share/control-plane/hooks"
bundled_git_hooks_dir="${bundled_hooks_dir}/git"
exec_policy_library_path="${CONTROL_PLANE_EXEC_POLICY_LIBRARY:-/usr/local/lib/libcontrol_plane_exec_policy.so}"
exec_policy_rules_path="${CONTROL_PLANE_EXEC_POLICY_RULES_FILE:-${bundled_hooks_dir}/preToolUse/deny-rules.yaml}"
effective_ld_preload="${LD_PRELOAD:-}"
copilot_hooks_dir="${copilot_state_dir}/hooks"
copilot_logs_dir="${copilot_state_dir}/logs"
copilot_agents_dir="${copilot_state_dir}/agents"
copilot_mcp_config_path="${copilot_state_dir}/mcp-config.json"
authorized_keys_path="${control_plane_home}/.ssh/authorized_keys"
kube_dir="${control_plane_home}/.kube"
kubeconfig_path="${kube_dir}/config"
service_account_dir="/var/run/secrets/kubernetes.io/serviceaccount"
runtime_config_dir="${control_plane_home}/.config/control-plane"
runtime_config_path="${runtime_config_dir}/runtime.env"
copilot_token_path="${runtime_config_dir}/copilot-github-token"
managed_runtime_dir="${CONTROL_PLANE_MANAGED_RUNTIME_DIR:-/var/lib/control-plane/managed-runtime}"
managed_copilot_home="${CONTROL_PLANE_MANAGED_COPILOT_HOME:-${managed_runtime_dir}/copilot-home}"
managed_copilot_hooks_dir="${managed_copilot_home}/hooks"
git_config_path="${CONTROL_PLANE_MANAGED_GIT_CONFIG_PATH:-${managed_runtime_dir}/gitconfig}"
compat_git_config_path="${control_plane_home}/.gitconfig"
copilot_config_json_file="${COPILOT_CONFIG_JSON_FILE:-}"
gh_github_token="${GH_GITHUB_TOKEN:-}"
gh_github_token_file="${GH_GITHUB_TOKEN_FILE:-}"
gh_hosts_yml_file="${GH_HOSTS_YML_FILE:-}"
copilot_github_token="${COPILOT_GITHUB_TOKEN:-}"
git_user_name="${CONTROL_PLANE_GIT_USER_NAME:-}"
git_user_email="${CONTROL_PLANE_GIT_USER_EMAIL:-}"
audit_log_max_records="${CONTROL_PLANE_AUDIT_LOG_MAX_RECORDS:-10000}"
copilot_nice_level="${CONTROL_PLANE_COPILOT_NICE_LEVEL:-10}"
job_namespace="${CONTROL_PLANE_JOB_NAMESPACE:-${CONTROL_PLANE_K8S_NAMESPACE:-default}}"
job_workspace_pvc="${CONTROL_PLANE_JOB_WORKSPACE_PVC:-}"
job_workspace_mount_path="${CONTROL_PLANE_JOB_WORKSPACE_MOUNT_PATH:-${CONTROL_PLANE_WORKSPACE_MOUNT_PATH:-/workspace}}"
job_workspace_subpath="${CONTROL_PLANE_JOB_WORKSPACE_SUBPATH:-${CONTROL_PLANE_WORKSPACE_SUBPATH:-workspace}}"
job_input_mount_path="${CONTROL_PLANE_JOB_INPUT_MOUNT_PATH:-/var/run/control-plane/job-inputs}"
job_transfer_root="${CONTROL_PLANE_JOB_TRANSFER_ROOT:-${tmp_dir}/job-transfers}"
job_transfer_image="${CONTROL_PLANE_JOB_TRANSFER_IMAGE:-}"
job_transfer_host="${CONTROL_PLANE_JOB_TRANSFER_HOST:-control-plane.${CONTROL_PLANE_K8S_NAMESPACE:-default}.svc.cluster.local}"
job_transfer_port="${CONTROL_PLANE_JOB_TRANSFER_PORT:-2222}"
job_transfer_user="${CONTROL_PLANE_JOB_TRANSFER_USER:-${control_plane_user}}"

if [[ "$(id -u)" -ne 0 ]]; then
  printf '%s\n' \
    'control-plane-entrypoint must start as root to prepare mounted state and SSH host keys.' \
    'Rerun the container with --user 0:0, or set runAsUser: 0 in Kubernetes.' \
    >&2
  exit 1
fi

case ":${effective_ld_preload}:" in
  *":${exec_policy_library_path}:"*)
    ;;
  "::")
    effective_ld_preload="${exec_policy_library_path}"
    ;;
  *)
    effective_ld_preload="${exec_policy_library_path}:${effective_ld_preload}"
    ;;
esac

if [[ ! "${audit_log_max_records}" =~ ^[0-9]+$ ]] || (( audit_log_max_records <= 0 )); then
  printf 'CONTROL_PLANE_AUDIT_LOG_MAX_RECORDS must be a positive integer: %s\n' "${audit_log_max_records}" >&2
  exit 1
fi

write_runtime_var() {
  printf '%s=%q\n' "$1" "$2"
}

safe_chown_tree() {
  local owner="$1"
  shift
  local target

  for target in "$@"; do
    [[ -e "${target}" ]] || continue
    find "${target}" \( -type l -o -type s \) -prune -o -exec chown "${owner}" {} +
  done
}

ensure_path_ownership() {
  local owner="$1"
  shift
  local target

  for target in "$@"; do
    [[ -e "${target}" ]] || continue
    chown "${owner}" "${target}"
  done
}

ensure_symlink_path() {
  local link_path="$1"
  local target_path="$2"

  if [[ -L "${link_path}" ]]; then
    if [[ "$(readlink "${link_path}")" == "${target_path}" ]]; then
      return 0
    fi
    rm -f "${link_path}"
  elif [[ -e "${link_path}" ]]; then
    rm -rf "${link_path}"
  fi

  ln -s "${target_path}" "${link_path}"
}

capability_bit() {
  case "$1" in
    CHOWN) printf '0\n' ;;
    AUDIT_WRITE) printf '29\n' ;;
    DAC_OVERRIDE) printf '1\n' ;;
    FOWNER) printf '3\n' ;;
    SETGID) printf '6\n' ;;
    SETUID) printf '7\n' ;;
    SYS_CHROOT) printf '18\n' ;;
    *)
      printf 'Unsupported capability name: %s\n' "$1" >&2
      exit 1
      ;;
  esac
}

has_effective_capability() {
  local capability_name="$1"
  local capability_mask="$2"
  local bit

  bit="$(capability_bit "${capability_name}")"
  (( (16#${capability_mask} & (1 << bit)) != 0 ))
}

command_uses_sshd() {
  local command_basename

  if [[ $# -eq 0 ]]; then
    return 0
  fi

  command_basename="$(basename -- "$1")"
  [[ "${command_basename}" == "sshd" ]]
}

require_container_capabilities() {
  local capability_mask
  local missing=()
  local capability_name

  [[ "$(id -u)" -eq 0 ]] || return 0
  capability_mask="$(awk '/^CapEff:/ { print $2 }' /proc/self/status)"
  [[ -n "${capability_mask}" ]] || return 0

  for capability_name in CHOWN DAC_OVERRIDE FOWNER; do
    if ! has_effective_capability "${capability_name}" "${capability_mask}"; then
      missing+=("${capability_name}")
    fi
  done

  if command_uses_sshd "$@"; then
    for capability_name in AUDIT_WRITE SETGID SETUID SYS_CHROOT; do
      if ! has_effective_capability "${capability_name}" "${capability_mask}"; then
        missing+=("${capability_name}")
      fi
    done
  fi

  if [[ ${#missing[@]} -gt 0 ]]; then
    printf 'Missing Linux capabilities for control-plane startup: %s\n' "${missing[*]}" >&2
    if command_uses_sshd "$@"; then
      printf '%s\n' \
        'Keep drop: ALL only when you re-add AUDIT_WRITE,CHOWN,DAC_OVERRIDE,FOWNER,SETGID,SETUID,SYS_CHROOT, or run the container privileged.' \
        'SSH requires AUDIT_WRITE plus SETUID/SETGID and SYS_CHROOT for privilege separation and PTY login accounting, and the entrypoint still needs ownership-related capabilities on mounted state.' \
        >&2
    else
      printf '%s\n' \
        'Non-SSH startup still needs CHOWN,DAC_OVERRIDE,FOWNER on mounted state. Direct sshd startup adds AUDIT_WRITE,SETGID,SETUID,SYS_CHROOT on top of that.' \
        >&2
    fi
    exit 1
  fi
}

write_private_file() {
  local target_path="$1"
  local content="$2"
  local owner="$3"

  if [[ -z "${content}" ]]; then
    rm -f "${target_path}"
    return
  fi

  (
    umask 077
    printf '%s' "${content}" > "${target_path}"
  )
  chown "${owner}" "${target_path}"
  chmod 600 "${target_path}"
}

require_regular_file_or_absent() {
  local target_path="$1"
  local description="$2"

  if [[ -e "${target_path}" ]] && [[ ! -f "${target_path}" ]]; then
    printf 'Refusing to use non-file %s at %s\n' "${description}" "${target_path}" >&2
    exit 1
  fi
}

require_regular_file() {
  local target_path="$1"
  local description="$2"

  if [[ ! -e "${target_path}" ]]; then
    printf 'Expected %s at %s\n' "${description}" "${target_path}" >&2
    exit 1
  fi

  if [[ ! -f "${target_path}" ]]; then
    printf 'Refusing to use non-file %s at %s\n' "${description}" "${target_path}" >&2
    exit 1
  fi
}

require_json_object_file() {
  local target_path="$1"
  local description="$2"

  if ! jq -e -s 'length == 1 and (.[0] | type == "object")' "${target_path}" >/dev/null; then
    printf 'Expected %s at %s to contain a single top-level JSON object\n' "${description}" "${target_path}" >&2
    exit 1
  fi
}

merge_json_object_file() {
  local target_path="$1"
  local overlay_path="$2"
  local owner="$3"
  local base_tmp
  local merged_tmp

  [[ -n "${overlay_path}" ]] || return 0

  require_regular_file_or_absent "${target_path}" "Copilot config path"
  require_regular_file "${overlay_path}" "Copilot config source"

  base_tmp="$(mktemp)"
  merged_tmp="$(mktemp)"

  if [[ -f "${target_path}" ]]; then
    require_json_object_file "${target_path}" "existing Copilot config"
    cp "${target_path}" "${base_tmp}"
  else
    printf '%s\n' '{}' > "${base_tmp}"
  fi

  require_json_object_file "${overlay_path}" "injected Copilot config"

  if ! jq -s '
    def deepmerge($base; $overlay):
      if ($base | type) == "object" and ($overlay | type) == "object" then
        reduce (($base + $overlay) | keys_unsorted[]) as $key
          ({};
           .[$key] =
             if ($base | has($key)) and ($overlay | has($key)) then
               deepmerge($base[$key]; $overlay[$key])
             elif ($overlay | has($key)) then
               $overlay[$key]
             else
               $base[$key]
             end)
      else
        $overlay
      end;
    deepmerge(.[0]; .[1])
  ' "${base_tmp}" "${overlay_path}" > "${merged_tmp}"; then
    rm -f "${base_tmp}" "${merged_tmp}"
    exit 1
  fi

  cat "${merged_tmp}" > "${target_path}"
  chown "${owner}" "${target_path}"
  chmod 600 "${target_path}"
  rm -f "${base_tmp}" "${merged_tmp}"
}

write_gh_hosts_from_token() {
  local target_path="$1"
  local github_token="$2"
  local owner="$3"
  local gh_hosts_content

  [[ -n "${github_token}" ]] || return 0

  printf -v gh_hosts_content '%s\n%s\n%s\n' \
    'github.com:' \
    "    oauth_token: ${github_token}" \
    '    git_protocol: https'
  write_private_file "${target_path}" "${gh_hosts_content}" "${owner}"
}

configure_gh_hosts() {
  local gh_hosts_content=""

  require_regular_file_or_absent "${gh_hosts_path}" "gh hosts config path"

  if [[ -n "${gh_hosts_yml_file}" ]]; then
    require_regular_file "${gh_hosts_yml_file}" "gh hosts source"
    gh_hosts_content="$(cat "${gh_hosts_yml_file}")"
    if [[ -z "${gh_hosts_content}" ]]; then
      printf 'Refusing to install an empty gh hosts source from %s\n' "${gh_hosts_yml_file}" >&2
      exit 1
    fi
    write_private_file "${gh_hosts_path}" "${gh_hosts_content}" "${control_plane_user}:${control_plane_user}"
    return
  fi

  if [[ -z "${gh_github_token}" ]] && [[ -n "${gh_github_token_file}" ]]; then
    require_regular_file "${gh_github_token_file}" "gh GitHub token source"
    IFS= read -r gh_github_token < "${gh_github_token_file}" || true
    if [[ -z "${gh_github_token}" ]]; then
      printf 'Refusing to install an empty gh GitHub token from %s\n' "${gh_github_token_file}" >&2
      exit 1
    fi
  fi

  write_gh_hosts_from_token "${gh_hosts_path}" "${gh_github_token}" "${control_plane_user}:${control_plane_user}"
}

configure_copilot() {
  merge_json_object_file "${copilot_config_path}" "${copilot_config_json_file}" "${control_plane_user}:${control_plane_user}"
}

ensure_ssh_host_key() {
  local key_type="$1"
  local key_basename="$2"
  local persistent_key_path="${host_key_dir}/${key_basename}"
  local etc_key_path="/etc/ssh/${key_basename}"

  if [[ -e "${persistent_key_path}" ]] && [[ ! -f "${persistent_key_path}" ]]; then
    printf 'Refusing to use non-file SSH host key path at %s\n' "${persistent_key_path}" >&2
    exit 1
  fi

  if [[ ! -f "${persistent_key_path}" ]]; then
    ssh-keygen -q -N '' -t "${key_type}" -f "${persistent_key_path}"
  fi

  if [[ ! -f "${persistent_key_path}.pub" ]]; then
    ssh-keygen -y -f "${persistent_key_path}" > "${persistent_key_path}.pub"
  fi

  chown root:root "${persistent_key_path}" "${persistent_key_path}.pub"
  chmod 600 "${persistent_key_path}"
  chmod 644 "${persistent_key_path}.pub"

  ln -sfn "${persistent_key_path}" "${etc_key_path}"
  ln -sfn "${persistent_key_path}.pub" "${etc_key_path}.pub"
}

remove_ssh_host_key() {
  local key_basename="$1"
  local persistent_key_path="${host_key_dir}/${key_basename}"
  local etc_key_path="/etc/ssh/${key_basename}"

  if [[ -e "${persistent_key_path}" ]] && [[ ! -f "${persistent_key_path}" ]]; then
    printf 'Refusing to remove non-file SSH host key path at %s\n' "${persistent_key_path}" >&2
    exit 1
  fi

  rm -f \
    "${persistent_key_path}" \
    "${persistent_key_path}.pub" \
    "${etc_key_path}" \
    "${etc_key_path}.pub"
}

install_bundled_control_plane_skills() {
  local source_dir
  local skill_name
  local target_dir
  local nullglob_was_set=0

  [[ -d "${bundled_skills_dir}" ]] || return 0

  mkdir -p "${copilot_skills_dir}"
  if shopt -q nullglob; then
    nullglob_was_set=1
  fi
  shopt -s nullglob
  for source_dir in "${bundled_skills_dir}"/*; do
    [[ -d "${source_dir}" ]] || continue
    skill_name="$(basename "${source_dir}")"
    target_dir="${copilot_skills_dir}/${skill_name}"
    rm -rf "${target_dir}"
    mkdir -p "${target_dir}"
    cp -R "${source_dir}/." "${target_dir}/"
    find "${target_dir}" -type d -exec chmod 755 {} +
    find "${target_dir}" -type f -exec chmod 644 {} +
    safe_chown_tree "${control_plane_user}:${control_plane_user}" "${target_dir}"
  done
  if [[ "${nullglob_was_set}" -eq 0 ]]; then
    shopt -u nullglob
  fi
}

configure_managed_copilot_home() {
  require_regular_file_or_absent "${copilot_command_history_state_path}" "Copilot command history path"

  mkdir -p "${managed_runtime_dir}" "${managed_copilot_home}" "${copilot_logs_dir}" "${copilot_agents_dir}"
  touch "${copilot_command_history_state_path}"
  chown "${control_plane_user}:${control_plane_user}" "${copilot_command_history_state_path}"
  chmod 600 "${copilot_command_history_state_path}"
  chown "${control_plane_user}:${control_plane_user}" "${copilot_logs_dir}" "${copilot_agents_dir}"
  chown root:root "${managed_runtime_dir}" "${managed_copilot_home}"
  chmod 755 "${managed_runtime_dir}" "${managed_copilot_home}"

  ensure_symlink_path "${managed_copilot_home}/config.json" "${copilot_config_path}"
  ensure_symlink_path "${managed_copilot_home}/command-history-state.json" "${copilot_command_history_state_path}"
  ensure_symlink_path "${managed_copilot_home}/session-state" "${copilot_session_state_dir}"
  ensure_symlink_path "${managed_copilot_home}/logs" "${copilot_logs_dir}"
  ensure_symlink_path "${managed_copilot_home}/skills" "${copilot_skills_dir}"
  ensure_symlink_path "${managed_copilot_home}/agents" "${copilot_agents_dir}"
  ensure_symlink_path "${managed_copilot_home}/mcp-config.json" "${copilot_mcp_config_path}"

  chown -h root:root \
    "${managed_copilot_home}/config.json" \
    "${managed_copilot_home}/command-history-state.json" \
    "${managed_copilot_home}/session-state" \
    "${managed_copilot_home}/logs" \
    "${managed_copilot_home}/skills" \
    "${managed_copilot_home}/agents" \
    "${managed_copilot_home}/mcp-config.json"
}

install_bundled_control_plane_hooks() {
  [[ -d "${bundled_hooks_dir}" ]] || return 0

  mkdir -p "${managed_runtime_dir}" "${managed_copilot_home}"
  chown root:root "${managed_runtime_dir}" "${managed_copilot_home}"
  chmod 755 "${managed_runtime_dir}" "${managed_copilot_home}"

  ensure_symlink_path "${managed_copilot_hooks_dir}" "${bundled_hooks_dir}"
  ensure_symlink_path "${copilot_hooks_dir}" "${bundled_hooks_dir}"

  chown -h root:root "${managed_copilot_hooks_dir}" "${copilot_hooks_dir}"
}

configure_git() {
  if [[ -e "${git_config_path}" ]] && [[ ! -f "${git_config_path}" ]]; then
    printf 'Refusing to use non-file git config path at %s\n' "${git_config_path}" >&2
    exit 1
  fi

  if [[ ! -d "${bundled_git_hooks_dir}" ]]; then
    printf 'Expected bundled git hooks at %s\n' "${bundled_git_hooks_dir}" >&2
    exit 1
  fi

  {
    printf '[core]\n'
    printf '    hooksPath = %s\n' "${bundled_git_hooks_dir}"

    if [[ -n "${git_user_name}" ]] || [[ -n "${git_user_email}" ]]; then
      printf '[user]\n'
      if [[ -n "${git_user_name}" ]]; then
        printf '    name = %s\n' "${git_user_name}"
      fi
      if [[ -n "${git_user_email}" ]]; then
        printf '    email = %s\n' "${git_user_email}"
      fi
    fi

    printf '[credential "https://github.com"]\n'
    printf '    helper =\n'
    printf '    helper = !gh auth git-credential\n'
    printf '[credential "https://gist.github.com"]\n'
    printf '    helper =\n'
    printf '    helper = !gh auth git-credential\n'
  } > "${git_config_path}"

  chown root:root "${git_config_path}"
  chmod 644 "${git_config_path}"
  ensure_symlink_path "${compat_git_config_path}" "${git_config_path}"
  chown -h root:root "${compat_git_config_path}"
}

require_container_capabilities "$@"

mkdir -p \
  "${copilot_state_dir}" \
  "${gh_config_dir}" \
  "${control_plane_home}/.config" \
  "${control_plane_home}/.local/share" \
  "${runtime_config_dir}" \
  "${kube_dir}" \
  "${control_plane_home}/.ssh" \
  "${copilot_skills_dir}" \
  "${copilot_logs_dir}" \
  "${copilot_agents_dir}" \
  "${control_plane_workspace}" \
  "${copilot_session_state_dir}" \
  "${audit_log_db_dir}" \
  "${screen_dir}" \
  "${tmp_root}" \
  "${hook_tmp_root}" \
  "${tmp_dir}" \
  "${node_compile_cache_dir}" \
  "${npm_cache_dir}" \
  "${cargo_home_dir}" \
  "${cargo_target_dir}" \
  "${job_transfer_root}" \
  "${host_key_dir}" \
  "/run/user/${control_plane_uid}" \
  /run/sshd \
  "${runtime_dir}"

safe_chown_tree "${control_plane_user}:${control_plane_user}" \
  "${control_plane_home}/.config" \
  "${runtime_config_dir}" \
  "${kube_dir}" \
  "${control_plane_home}/.ssh" \
  "${control_plane_workspace}" \
  "${audit_log_db_dir}" \
  "${job_transfer_root}" \
  "${screen_dir}" \
  "${tmp_root}" \
  "${hook_tmp_root}" \
  "${tmp_dir}" \
  "${node_compile_cache_dir}" \
  "${npm_cache_dir}" \
  "${cargo_home_dir}" \
  "${cargo_target_dir}" \
  "${runtime_dir}"
ensure_path_ownership "${control_plane_user}:${control_plane_user}" \
  "${copilot_state_dir}" \
  "${copilot_session_state_dir}" \
  "${copilot_skills_dir}" \
  "${copilot_logs_dir}" \
  "${copilot_agents_dir}" \
  "${audit_log_db_dir}" \
  "${screen_dir}" \
  "${tmp_root}" \
  "${hook_tmp_root}" \
  "${tmp_dir}" \
  "${node_compile_cache_dir}" \
  "${npm_cache_dir}" \
  "${cargo_home_dir}" \
  "${cargo_target_dir}" \
  "${job_transfer_root}" \
  "${runtime_dir}"
chown "${control_plane_user}:${control_plane_user}" \
  "/run/user/${control_plane_uid}" \
  "${control_plane_home}" \
  "${control_plane_home}/.local" \
  "${control_plane_home}/.local/share"
chown root:root "${host_key_dir}"
chown root:root /run/sshd
chmod 755 "${control_plane_home}"
chmod 700 \
  "${control_plane_home}/.ssh" \
  "${runtime_dir}" \
  "${tmp_root}" \
  "${hook_tmp_root}" \
  "${tmp_dir}" \
  "${node_compile_cache_dir}" \
  "${npm_cache_dir}" \
  "${cargo_home_dir}" \
  "${audit_log_db_dir}" \
  "${job_transfer_root}" \
  "${screen_dir}"
# Jobs need to read the public SSH host key from an unprivileged shell to seed known_hosts.
chmod 711 "${host_key_dir}"
chmod 755 /run/sshd

export XDG_RUNTIME_DIR="${runtime_dir}"
export CONTROL_PLANE_TMP_ROOT="${tmp_root}"
export CONTROL_PLANE_HOOK_TMP_ROOT="${hook_tmp_root}"
export TMPDIR="${tmp_dir}"
export NODE_COMPILE_CACHE="${node_compile_cache_dir}"
export NPM_CONFIG_CACHE="${npm_cache_dir}"
export SCREENDIR="${screen_dir}"
export CARGO_HOME="${cargo_home_dir}"
export CARGO_TARGET_DIR="${cargo_target_dir}"
export RUSTUP_HOME="${rustup_home_dir}"
export COPILOT_HOME="${managed_copilot_home}"
export GIT_CONFIG_GLOBAL="${git_config_path}"
export CONTROL_PLANE_RUNTIME_ENV_FILE="${runtime_config_path}"

touch "${authorized_keys_path}"
chmod 600 "${authorized_keys_path}"
chown "${control_plane_user}:${control_plane_user}" "${authorized_keys_path}"

if [[ -n "${SSH_PUBLIC_KEY:-}" ]] && ! grep -Fxq "${SSH_PUBLIC_KEY}" "${authorized_keys_path}"; then
  printf '%s\n' "${SSH_PUBLIC_KEY}" >> "${authorized_keys_path}"
fi

if [[ -n "${SSH_PUBLIC_KEY_FILE:-}" ]] && [[ -f "${SSH_PUBLIC_KEY_FILE}" ]]; then
  while IFS= read -r key; do
    [[ -z "${key}" ]] && continue
    if ! grep -Fxq "${key}" "${authorized_keys_path}"; then
      printf '%s\n' "${key}" >> "${authorized_keys_path}"
    fi
  done < "${SSH_PUBLIC_KEY_FILE}"
fi

if [[ -z "${copilot_github_token}" ]] && [[ -n "${COPILOT_GITHUB_TOKEN_FILE:-}" ]] && [[ -f "${COPILOT_GITHUB_TOKEN_FILE}" ]]; then
  IFS= read -r copilot_github_token < "${COPILOT_GITHUB_TOKEN_FILE}" || true
fi

write_private_file "${copilot_token_path}" "${copilot_github_token}" "${control_plane_user}:${control_plane_user}"

if [[ -z "${KUBECONFIG:-}" ]] \
  && [[ -n "${KUBERNETES_SERVICE_HOST:-}" ]] \
  && [[ -f "${service_account_dir}/token" ]] \
  && [[ -f "${service_account_dir}/ca.crt" ]] \
  && [[ ! -f "${kubeconfig_path}" ]]; then
  namespace="default"
  if [[ -f "${service_account_dir}/namespace" ]]; then
    namespace="$(cat "${service_account_dir}/namespace")"
  fi
  cat > "${kubeconfig_path}" <<EOF
apiVersion: v1
kind: Config
clusters:
  - cluster:
      certificate-authority: ${service_account_dir}/ca.crt
      server: https://${KUBERNETES_SERVICE_HOST}:${KUBERNETES_SERVICE_PORT_HTTPS:-443}
    name: in-cluster
contexts:
  - context:
      cluster: in-cluster
      namespace: ${namespace}
      user: ${control_plane_user}
    name: in-cluster
current-context: in-cluster
users:
  - name: ${control_plane_user}
    user:
      tokenFile: ${service_account_dir}/token
EOF
  chown "${control_plane_user}:${control_plane_user}" "${kubeconfig_path}"
  chmod 600 "${kubeconfig_path}"
  export KUBECONFIG="${kubeconfig_path}"
fi

runtime_config_tmp="$(mktemp "${runtime_config_path}.XXXXXX")"
{
  write_runtime_var CONTROL_PLANE_K8S_NAMESPACE "${CONTROL_PLANE_K8S_NAMESPACE:-default}"
  write_runtime_var CONTROL_PLANE_JOB_NAMESPACE "${job_namespace}"
  write_runtime_var CONTROL_PLANE_WORKSPACE "${CONTROL_PLANE_WORKSPACE:-/workspace}"
  write_runtime_var CONTROL_PLANE_WORKSPACE_PVC "${CONTROL_PLANE_WORKSPACE_PVC:-}"
  write_runtime_var CONTROL_PLANE_WORKSPACE_MOUNT_PATH "${CONTROL_PLANE_WORKSPACE_MOUNT_PATH:-/workspace}"
  write_runtime_var CONTROL_PLANE_WORKSPACE_SUBPATH "${CONTROL_PLANE_WORKSPACE_SUBPATH:-workspace}"
  if [[ -n "${CONTROL_PLANE_COPILOT_SESSION_PVC:-}" ]]; then
    write_runtime_var CONTROL_PLANE_COPILOT_SESSION_PVC "${CONTROL_PLANE_COPILOT_SESSION_PVC}"
  fi
  write_runtime_var CONTROL_PLANE_COPILOT_SESSION_GH_SUBPATH "${CONTROL_PLANE_COPILOT_SESSION_GH_SUBPATH:-state/gh}"
  write_runtime_var CONTROL_PLANE_COPILOT_SESSION_SSH_SUBPATH "${CONTROL_PLANE_COPILOT_SESSION_SSH_SUBPATH:-state/ssh}"
  write_runtime_var CONTROL_PLANE_JOB_WORKSPACE_PVC "${job_workspace_pvc}"
  write_runtime_var CONTROL_PLANE_JOB_WORKSPACE_MOUNT_PATH "${job_workspace_mount_path}"
  write_runtime_var CONTROL_PLANE_JOB_WORKSPACE_SUBPATH "${job_workspace_subpath}"
  write_runtime_var CONTROL_PLANE_JOB_INPUT_MOUNT_PATH "${job_input_mount_path}"
  write_runtime_var CONTROL_PLANE_POD_NAME "${CONTROL_PLANE_POD_NAME:-${HOSTNAME:-}}"
  write_runtime_var CONTROL_PLANE_POD_NAMESPACE "${CONTROL_PLANE_POD_NAMESPACE:-${CONTROL_PLANE_K8S_NAMESPACE:-default}}"
  if [[ -n "${CONTROL_PLANE_POD_UID:-}" ]]; then
    write_runtime_var CONTROL_PLANE_POD_UID "${CONTROL_PLANE_POD_UID}"
  fi
  if [[ -n "${CONTROL_PLANE_NODE_NAME:-}" ]]; then
    write_runtime_var CONTROL_PLANE_NODE_NAME "${CONTROL_PLANE_NODE_NAME}"
  fi
  write_runtime_var CONTROL_PLANE_HOST_KEY_DIR "${host_key_dir}"
  if [[ -n "${CONTROL_PLANE_SCREEN_SESSION:-}" ]]; then
    write_runtime_var CONTROL_PLANE_SCREEN_SESSION "${CONTROL_PLANE_SCREEN_SESSION}"
  fi
  if [[ -n "${CONTROL_PLANE_COPILOT_SESSION:-}" ]]; then
    write_runtime_var CONTROL_PLANE_COPILOT_SESSION "${CONTROL_PLANE_COPILOT_SESSION}"
  fi
  write_runtime_var CONTROL_PLANE_FAST_EXECUTION_ENABLED "${CONTROL_PLANE_FAST_EXECUTION_ENABLED:-0}"
  if [[ -n "${CONTROL_PLANE_FAST_EXECUTION_IMAGE:-}" ]]; then
    write_runtime_var CONTROL_PLANE_FAST_EXECUTION_IMAGE "${CONTROL_PLANE_FAST_EXECUTION_IMAGE}"
  fi
  write_runtime_var CONTROL_PLANE_FAST_EXECUTION_IMAGE_PULL_POLICY "${CONTROL_PLANE_FAST_EXECUTION_IMAGE_PULL_POLICY:-IfNotPresent}"
  if [[ -n "${CONTROL_PLANE_FAST_EXECUTION_BOOTSTRAP_IMAGE:-}" ]]; then
    write_runtime_var CONTROL_PLANE_FAST_EXECUTION_BOOTSTRAP_IMAGE "${CONTROL_PLANE_FAST_EXECUTION_BOOTSTRAP_IMAGE}"
  fi
  write_runtime_var CONTROL_PLANE_FAST_EXECUTION_BOOTSTRAP_IMAGE_PULL_POLICY "${CONTROL_PLANE_FAST_EXECUTION_BOOTSTRAP_IMAGE_PULL_POLICY:-IfNotPresent}"
  write_runtime_var CONTROL_PLANE_FAST_EXECUTION_START_TIMEOUT "${CONTROL_PLANE_FAST_EXECUTION_START_TIMEOUT:-300s}"
  write_runtime_var CONTROL_PLANE_FAST_EXECUTION_PORT "${CONTROL_PLANE_FAST_EXECUTION_PORT:-8080}"
  write_runtime_var CONTROL_PLANE_FAST_EXECUTION_HOME "${CONTROL_PLANE_FAST_EXECUTION_HOME:-/root}"
  write_runtime_var CONTROL_PLANE_FAST_EXECUTION_ENVIRONMENT_PVC_PREFIX "${CONTROL_PLANE_FAST_EXECUTION_ENVIRONMENT_PVC_PREFIX:-node-workspace}"
  if [[ -n "${CONTROL_PLANE_FAST_EXECUTION_ENVIRONMENT_STORAGE_CLASS:-}" ]]; then
    write_runtime_var CONTROL_PLANE_FAST_EXECUTION_ENVIRONMENT_STORAGE_CLASS "${CONTROL_PLANE_FAST_EXECUTION_ENVIRONMENT_STORAGE_CLASS}"
  fi
  write_runtime_var CONTROL_PLANE_FAST_EXECUTION_ENVIRONMENT_SIZE "${CONTROL_PLANE_FAST_EXECUTION_ENVIRONMENT_SIZE:-10Gi}"
  write_runtime_var CONTROL_PLANE_FAST_EXECUTION_ENVIRONMENT_MOUNT_PATH "${CONTROL_PLANE_FAST_EXECUTION_ENVIRONMENT_MOUNT_PATH:-/environment}"
  write_runtime_var CONTROL_PLANE_FAST_EXECUTION_CPU_REQUEST "${CONTROL_PLANE_FAST_EXECUTION_CPU_REQUEST:-250m}"
  write_runtime_var CONTROL_PLANE_FAST_EXECUTION_CPU_LIMIT "${CONTROL_PLANE_FAST_EXECUTION_CPU_LIMIT:-2}"
  write_runtime_var CONTROL_PLANE_FAST_EXECUTION_MEMORY_REQUEST "${CONTROL_PLANE_FAST_EXECUTION_MEMORY_REQUEST:-256Mi}"
  write_runtime_var CONTROL_PLANE_FAST_EXECUTION_MEMORY_LIMIT "${CONTROL_PLANE_FAST_EXECUTION_MEMORY_LIMIT:-2Gi}"
  write_runtime_var CONTROL_PLANE_FAST_EXECUTION_REQUEST_TIMEOUT_SEC "${CONTROL_PLANE_FAST_EXECUTION_REQUEST_TIMEOUT_SEC:-3600}"
  if [[ -n "${git_user_name}" ]]; then
    write_runtime_var CONTROL_PLANE_GIT_USER_NAME "${git_user_name}"
  fi
  if [[ -n "${git_user_email}" ]]; then
    write_runtime_var CONTROL_PLANE_GIT_USER_EMAIL "${git_user_email}"
  fi
  write_runtime_var CONTROL_PLANE_COPILOT_WORKSPACE "${CONTROL_PLANE_COPILOT_WORKSPACE:-${CONTROL_PLANE_WORKSPACE:-/workspace}}"
  if [[ -n "${CONTROL_PLANE_COPILOT_BIN:-}" ]]; then
    write_runtime_var CONTROL_PLANE_COPILOT_BIN "${CONTROL_PLANE_COPILOT_BIN}"
  fi
  write_runtime_var CONTROL_PLANE_COPILOT_NICE_LEVEL "${copilot_nice_level}"
  if [[ -n "${CONTROL_PLANE_RUST_HOOK_IMAGE:-}" ]]; then
    write_runtime_var CONTROL_PLANE_RUST_HOOK_IMAGE "${CONTROL_PLANE_RUST_HOOK_IMAGE}"
  fi
  write_runtime_var CONTROL_PLANE_JOB_SERVICE_ACCOUNT "${CONTROL_PLANE_JOB_SERVICE_ACCOUNT:-}"
  write_runtime_var CONTROL_PLANE_JOB_IMAGE_PULL_POLICY "${CONTROL_PLANE_JOB_IMAGE_PULL_POLICY:-IfNotPresent}"
  write_runtime_var CONTROL_PLANE_JOB_CPU_REQUEST "${CONTROL_PLANE_JOB_CPU_REQUEST:-100m}"
  write_runtime_var CONTROL_PLANE_JOB_CPU_LIMIT "${CONTROL_PLANE_JOB_CPU_LIMIT:-1000m}"
  write_runtime_var CONTROL_PLANE_JOB_MEMORY_REQUEST "${CONTROL_PLANE_JOB_MEMORY_REQUEST:-128Mi}"
  write_runtime_var CONTROL_PLANE_JOB_MEMORY_LIMIT "${CONTROL_PLANE_JOB_MEMORY_LIMIT:-1Gi}"
  write_runtime_var CONTROL_PLANE_JOB_TRANSFER_ROOT "${job_transfer_root}"
  if [[ -n "${job_transfer_image}" ]]; then
    write_runtime_var CONTROL_PLANE_JOB_TRANSFER_IMAGE "${job_transfer_image}"
  fi
  write_runtime_var CONTROL_PLANE_JOB_TRANSFER_HOST "${job_transfer_host}"
  write_runtime_var CONTROL_PLANE_JOB_TRANSFER_PORT "${job_transfer_port}"
  write_runtime_var CONTROL_PLANE_JOB_TRANSFER_USER "${job_transfer_user}"
  write_runtime_var COPILOT_HOME "${managed_copilot_home}"
  write_runtime_var CONTROL_PLANE_EXEC_POLICY_LIBRARY "${exec_policy_library_path}"
  write_runtime_var CONTROL_PLANE_EXEC_POLICY_RULES_FILE "${exec_policy_rules_path}"
  write_runtime_var CONTROL_PLANE_TMP_ROOT "${tmp_root}"
  write_runtime_var CONTROL_PLANE_HOOK_TMP_ROOT "${hook_tmp_root}"
  write_runtime_var CONTROL_PLANE_NODE_COMPILE_CACHE_DIR "${node_compile_cache_dir}"
  write_runtime_var CONTROL_PLANE_NPM_CACHE_DIR "${npm_cache_dir}"
  write_runtime_var CONTROL_PLANE_AUDIT_LOG_DB_PATH "${audit_log_db_path}"
  write_runtime_var CONTROL_PLANE_AUDIT_LOG_MAX_RECORDS "${audit_log_max_records}"
  write_runtime_var GIT_CONFIG_GLOBAL "${git_config_path}"
  write_runtime_var CONTROL_PLANE_RUNTIME_ENV_FILE "${runtime_config_path}"
  write_runtime_var XDG_RUNTIME_DIR "${runtime_dir}"
  write_runtime_var TMPDIR "${tmp_dir}"
  write_runtime_var LD_PRELOAD "${effective_ld_preload}"
  write_runtime_var NODE_COMPILE_CACHE "${node_compile_cache_dir}"
  write_runtime_var NPM_CONFIG_CACHE "${npm_cache_dir}"
  write_runtime_var SCREENDIR "${screen_dir}"
  write_runtime_var PATH "${PATH}"
  write_runtime_var CARGO_HOME "${cargo_home_dir}"
  write_runtime_var CARGO_TARGET_DIR "${cargo_target_dir}"
  write_runtime_var RUSTUP_HOME "${rustup_home_dir}"
  write_runtime_var LANG "C.UTF-8"
  write_runtime_var LC_CTYPE "C.UTF-8"
  if [[ -n "${TZ:-}" ]]; then
    write_runtime_var TZ "${TZ}"
  fi
  write_runtime_var KUBECONFIG "${KUBECONFIG:-}"
  if [[ -n "${copilot_github_token}" ]]; then
    write_runtime_var CONTROL_PLANE_COPILOT_GITHUB_TOKEN_FILE "${copilot_token_path}"
  fi
} > "${runtime_config_tmp}"
mv "${runtime_config_tmp}" "${runtime_config_path}"
chown "${control_plane_user}:${control_plane_user}" "${runtime_config_path}"
chmod 600 "${runtime_config_path}"

configure_managed_copilot_home
install_bundled_control_plane_hooks
install_bundled_control_plane_skills
configure_copilot
configure_gh_hosts
configure_git
remove_ssh_host_key ssh_host_rsa_key
remove_ssh_host_key ssh_host_ecdsa_key
ensure_ssh_host_key ed25519 ssh_host_ed25519_key

if [[ $# -eq 0 ]]; then
  set -- /usr/sbin/sshd -D -e -f /etc/ssh/sshd_config
fi

exec "$@"
