#!/usr/bin/env bash
set -euo pipefail

manifest_path="${1:?usage: install-git-skills-from-manifest <manifest-path> <destination-root>}"
destination_root="${2:?usage: install-git-skills-from-manifest <manifest-path> <destination-root>}"
checkout_root="$(mktemp -d)"

cleanup() {
  rm -rf "${checkout_root}"
}
trap cleanup EXIT

require_command() {
  local command_name="$1"

  command -v "${command_name}" >/dev/null 2>&1 || {
    printf 'Missing required command: %s\n' "${command_name}" >&2
    exit 1
  }
}

parse_manifest() {
  awk '
    function trim(value) {
      sub(/^[[:space:]]+/, "", value)
      sub(/[[:space:]]+$/, "", value)
      return value
    }

    function normalize_value(value) {
      sub(/[[:space:]]+#.*$/, "", value)
      value = trim(value)

      if ((value ~ /^".*"$/) || (value ~ /^'\''.*'\''$/)) {
        value = substr(value, 2, length(value) - 2)
      }

      return value
    }

    function fail(message) {
      printf "%s:%d: %s\n", FILENAME, NR, message > "/dev/stderr"
      exit 1
    }

    function flush_entry(    item_index) {
      if (repository == "") {
        return
      }

      if (git_ref == "") {
        fail("manifest entry is missing ref")
      }

      if (skill_count == 0) {
        fail("manifest entry is missing skills")
      }

      for (item_index = 1; item_index <= skill_count; item_index++) {
        printf "%s\t%s\t%s\n", repository, git_ref, skills[item_index]
      }

      delete skills
      skill_count = 0
      repository = ""
      git_ref = ""
      in_skills = 0
    }

    BEGIN {
      skill_count = 0
      in_skills = 0
    }

    {
      line = $0
      sub(/\r$/, "", line)

      if (line ~ /^[[:space:]]*$/) {
        next
      }

      if (line ~ /^[[:space:]]*---[[:space:]]*$/) {
        next
      }

      if (line ~ /^[[:space:]]*#/) {
        next
      }

      if (line ~ /^- repository:[[:space:]]*/) {
        flush_entry()
        repository = line
        sub(/^- repository:[[:space:]]*/, "", repository)
        repository = normalize_value(repository)

        if (repository == "") {
          fail("manifest entry is missing repository")
        }

        next
      }

      if (line ~ /^  ref:[[:space:]]*/) {
        if (repository == "") {
          fail("ref must follow repository")
        }

        git_ref = line
        sub(/^  ref:[[:space:]]*/, "", git_ref)
        git_ref = normalize_value(git_ref)

        if (git_ref == "") {
          fail("manifest entry is missing ref value")
        }

        in_skills = 0
        next
      }

      if (line ~ /^  skills:[[:space:]]*$/) {
        if (repository == "") {
          fail("skills must follow repository")
        }

        in_skills = 1
        next
      }

      if (line ~ /^    -[[:space:]]*/) {
        if (!in_skills) {
          fail("skill path must appear under skills")
        }

        skill_path = line
        sub(/^    -[[:space:]]*/, "", skill_path)
        skill_path = normalize_value(skill_path)

        if (skill_path == "") {
          fail("skill path is empty")
        }

        skills[++skill_count] = skill_path
        next
      }

      fail("unsupported manifest syntax: " line)
    }

    END {
      flush_entry()
    }
  ' "${manifest_path}"
}

require_command git
test -f "${manifest_path}"
install -d -m 0755 "${destination_root}"

declare -A checkout_dirs=()
declare -A installed_skills=()
installed_count=0

while IFS=$'\t' read -r repository_url git_ref skill_path; do
  checkout_key="${repository_url}|${git_ref}"
  checkout_dir="${checkout_dirs["${checkout_key}"]-}"

  if [[ -z "${checkout_dir}" ]]; then
    checkout_dir="$(mktemp -d "${checkout_root}/repo.XXXXXX")/repo"
    git clone "${repository_url}" "${checkout_dir}" >&2
    git -C "${checkout_dir}" checkout --detach "${git_ref}" >&2
    checkout_dirs["${checkout_key}"]="${checkout_dir}"
  fi

  skill_name="${skill_path%/}"
  skill_name="${skill_name##*/}"
  source_skill_dir="${checkout_dir}/${skill_path}"
  destination_dir="${destination_root%/}/${skill_name}"

  [[ -n "${skill_name}" ]] || {
    printf 'Could not determine skill name from path: %s\n' "${skill_path}" >&2
    exit 1
  }

  [[ -z "${installed_skills["${skill_name}"]-}" ]] || {
    printf 'Duplicate installed skill name: %s\n' "${skill_name}" >&2
    printf '  first: %s\n' "${installed_skills["${skill_name}"]}" >&2
    printf '  next:  %s@%s:%s\n' "${repository_url}" "${git_ref}" "${skill_path}" >&2
    exit 1
  }

  test -f "${source_skill_dir}/SKILL.md" || {
    printf 'Missing SKILL.md for manifest entry: %s@%s:%s\n' "${repository_url}" "${git_ref}" "${skill_path}" >&2
    exit 1
  }

  installed_skills["${skill_name}"]="${repository_url}@${git_ref}:${skill_path}"
  rm -rf "${destination_dir}"
  cp -a "${source_skill_dir}" "${destination_dir}"
  installed_count=$((installed_count + 1))
done < <(parse_manifest "${manifest_path}")

(( installed_count > 0 )) || {
  printf 'Manifest did not define any skills: %s\n' "${manifest_path}" >&2
  exit 1
}
