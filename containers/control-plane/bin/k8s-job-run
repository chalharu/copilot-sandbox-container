#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  k8s-job-run --namespace NAME --image IMAGE [--job-name NAME] [--timeout 300s] [--input-mount-path PATH] [--mount-file SRC[:DEST]] -- COMMAND [ARG...]
USAGE
}

die() {
  printf 'k8s-job-run: %s\n' "$*" >&2
  exit 64
}

namespace="default"
image=""
job_name=""
timeout="300s"
input_mount_path="${CONTROL_PLANE_JOB_INPUT_MOUNT_PATH:-/var/run/control-plane/job-inputs}"
cleanup_policy="${CONTROL_PLANE_CLEANUP_JOBS:-always}"
created_job=""
mount_files=()
transfer_id=""

# shellcheck disable=SC2329,SC2317
cleanup() {
  if [[ -n "${created_job}" ]] && [[ "${cleanup_policy}" == "always" ]]; then
    kubectl delete job --namespace "${namespace}" "${created_job}" --ignore-not-found >/dev/null 2>&1 || true
  fi
  if [[ -n "${transfer_id}" ]]; then
    control-plane-job-transfer release-access --transfer-id "${transfer_id}" >/dev/null 2>&1 || true
  fi
}
trap cleanup EXIT

while [[ $# -gt 0 ]]; do
  case "$1" in
    --namespace)
      namespace="$2"
      shift 2
      ;;
    --image)
      image="$2"
      shift 2
      ;;
    --job-name)
      job_name="$2"
      shift 2
      ;;
    --timeout)
      timeout="$2"
      shift 2
      ;;
    --mount-file)
      mount_files+=("$2")
      shift 2
      ;;
    --input-mount-path)
      input_mount_path="$2"
      shift 2
      ;;
    --help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    *)
      die "unknown option: $1"
      ;;
  esac
done

[[ -n "${image}" ]] || die "--image is required"
[[ $# -gt 0 ]] || die "a command must be provided after --"

start_args=(--namespace "${namespace}" --image "${image}")
if [[ -n "${job_name}" ]]; then
  start_args+=(--job-name "${job_name}")
fi
if [[ ${#mount_files[@]} -gt 0 ]]; then
  start_args+=(--input-mount-path "${input_mount_path}")
  for mount_file in "${mount_files[@]}"; do
    start_args+=(--mount-file "${mount_file}")
  done
fi

created_job="$(k8s-job-start "${start_args[@]}" -- "$@" | tr -d '\n')"
if [[ ${#mount_files[@]} -gt 0 ]]; then
  transfer_id="$(kubectl get job --namespace "${namespace}" "${created_job}" -o jsonpath='{.metadata.annotations.control-plane\.github\.io/job-transfer-id}' 2>/dev/null || true)"
fi
k8s-job-wait --namespace "${namespace}" --job-name "${created_job}" --timeout "${timeout}"
pod_name="$(k8s-job-pod --namespace "${namespace}" --job-name "${created_job}" | tr -d '\n')"

if [[ -n "${pod_name}" ]]; then
  k8s-job-logs --namespace "${namespace}" --job-name "${created_job}"
  exit_code="$(kubectl get pod --namespace "${namespace}" "${pod_name}" -o jsonpath='{.status.containerStatuses[?(@.name=="execution")].state.terminated.exitCode}' 2>/dev/null || true)"
  if [[ -n "${exit_code}" ]]; then
    exit "${exit_code}"
  fi
fi

exit 0
