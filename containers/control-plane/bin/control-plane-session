#!/usr/bin/env bash
set -euo pipefail

runtime_config_file="${CONTROL_PLANE_RUNTIME_ENV_FILE:-${HOME:-/home/${USER:-copilot}}/.config/control-plane/runtime.env}"
if [[ -f "${runtime_config_file}" ]]; then
  # shellcheck disable=SC1090
  source "${runtime_config_file}"
fi

session_name="${CONTROL_PLANE_SCREEN_SESSION:-shell}"
copilot_session_name="${CONTROL_PLANE_COPILOT_SESSION:-copilot}"
copilot_workspace="${CONTROL_PLANE_COPILOT_WORKSPACE:-${CONTROL_PLANE_WORKSPACE:-/workspace}}"

prune_dead_sessions() {
  screen -wipe >/dev/null 2>&1 || true
}

attach_session() {
  local target_session="$1"

  exec screen -D -RR "${target_session}"
}

list_sessions() {
  prune_dead_sessions
  screen -list 2>/dev/null | awk '/^[[:space:]]*[0-9]+\./ && !/\(Dead/ {sub(/^[[:space:]]+/, "", $0); print}'
}

copilot_session_exists() {
  local session_line
  local session_id

  while IFS= read -r session_line; do
    [[ -n "${session_line}" ]] || continue
    session_id="${session_line%%[[:space:]]*}"
    if [[ "${session_id#*.}" == "${copilot_session_name}" ]]; then
      return 0
    fi
  done < <(list_sessions || true)

  return 1
}

create_copilot_session() {
  command -v control-plane-copilot >/dev/null 2>&1 || {
    printf '%s\n' 'control-plane-session: missing control-plane-copilot launcher' >&2
    exit 127
  }

  printf 'Starting Copilot session %s in %s...\n' "${copilot_session_name}" "${copilot_workspace}" >&2
  # shellcheck disable=SC2016
  exec screen -S "${copilot_session_name}" \
    bash -lc '
      set -euo pipefail
      mkdir -p -- "$1"
      cd -- "$1"
      exec control-plane-copilot
    ' \
    bash "${copilot_workspace}"
}

attach_or_create_copilot_session() {
  prune_dead_sessions
  if copilot_session_exists; then
    attach_session "${copilot_session_name}"
  fi

  create_copilot_session
}

if [[ "${1:-}" == "--command" ]]; then
  shift
  [[ $# -gt 0 ]] || {
    printf 'control-plane-session: --command requires a shell command\n' >&2
    exit 64
  }
  exec screen -DmS "${session_name}" bash -lc "$*"
fi

if [[ "${1:-}" == "--list" ]]; then
  list_sessions
  exit 0
fi

if [[ "${1:-}" == "--select" ]]; then
  attach_or_create_copilot_session
  exit 0
fi

attach_or_create_copilot_session
