#!/usr/bin/env bash
set -euo pipefail

runtime_config_file="${CONTROL_PLANE_RUNTIME_ENV_FILE:-${HOME:-/home/${USER:-copilot}}/.config/control-plane/runtime.env}"
if [[ -f "${runtime_config_file}" ]]; then
  # shellcheck disable=SC1090
  source "${runtime_config_file}"
fi

podman_bin="${CONTROL_PLANE_PODMAN_BIN:-/usr/bin/podman}"

podman_reports_userns_failure() {
  local stderr_path="$1"

  grep -Eiq 'cannot clone: Operation not permitted|cannot re-exec process|cannot set user namespace|creating new namespace.*Operation not permitted|newuidmap.*Operation not permitted|newgidmap.*Operation not permitted' "${stderr_path}"
}

podman_requests_migrate() {
  local stderr_path="$1"

  grep -Eiq 'invalid internal status, try resetting the pause process with "/usr/bin/podman system migrate"|unknown FS magic on ".*/run/netns/' "${stderr_path}"
}

podman_reports_network_device_failure() {
  local stderr_path="$1"

  grep -Eiq 'slirp4netns failed: .*open\("/dev/net/tun"\): No such file or directory|/dev/net/tun' "${stderr_path}"
}

running_in_kubernetes() {
  [[ -n "${KUBERNETES_SERVICE_HOST:-}" ]] || [[ -d /var/run/secrets/kubernetes.io/serviceaccount ]]
}

pod_uses_identity_user_namespace() {
  local container_start=""
  local host_start=""
  local map_size=""

  if ! read -r container_start host_start map_size _ < /proc/self/uid_map; then
    return 1
  fi

  [[ "${container_start}" == "0" ]] && [[ "${host_start}" == "0" ]] && [[ "${map_size}" == "4294967295" ]]
}

podman_reports_rootful_service_constraint() {
  local stderr_path="$1"

  grep -Eiq 'open /proc/sys/net/ipv4/ping_group_range: Read-only file system|opening file .*/sys/fs/cgroup/cgroup\.subtree_control.*Read-only file system|ioctl\(SIOCSIFFLAGS\): Operation not permitted|prctl drop bounding: Operation not permitted|remount /, flags: 0x44000: permission denied' "${stderr_path}"
}

run_podman_with_live_stderr() {
  local stderr_path="$1"
  shift
  local stderr_dir
  local stderr_fifo
  local tee_pid
  local status

  stderr_dir="$(mktemp -d "${TMPDIR%/}/control-plane-podman.stderr.XXXXXX")"
  stderr_fifo="${stderr_dir}/stderr"
  mkfifo "${stderr_fifo}"
  tee "${stderr_path}" < "${stderr_fifo}" >&2 &
  tee_pid=$!

  set +e
  "${podman_bin}" "$@" 2> "${stderr_fifo}"
  status=$?
  set -e

  rm -f "${stderr_fifo}"
  rmdir "${stderr_dir}"
  wait "${tee_pid}"

  return "${status}"
}

run_podman_capture_stdout_live_stderr() {
  local stdout_path="$1"
  local stderr_path="$2"
  shift 2
  local stderr_dir
  local stderr_fifo
  local tee_pid
  local status

  stderr_dir="$(mktemp -d "${TMPDIR%/}/control-plane-podman.stderr.XXXXXX")"
  stderr_fifo="${stderr_dir}/stderr"
  mkfifo "${stderr_fifo}"
  tee "${stderr_path}" < "${stderr_fifo}" >&2 &
  tee_pid=$!

  set +e
  "${podman_bin}" "$@" > "${stdout_path}" 2> "${stderr_fifo}"
  status=$?
  set -e

  rm -f "${stderr_fifo}"
  rmdir "${stderr_dir}"
  wait "${tee_pid}"

  return "${status}"
}

podman_command_needs_direct_exec() {
  local subcommand="${1:-}"
  local expecting_value=0
  local arg

  case "${subcommand}" in
    attach)
      return 0
      ;;
    exec|run)
      ;;
    *)
      return 1
      ;;
  esac
  shift

  for arg in "$@"; do
    if [[ "${expecting_value}" -eq 1 ]]; then
      if [[ "${arg}" == stdin ]]; then
        return 0
      fi
      expecting_value=0
      continue
    fi

    if [[ "${arg}" == "--" ]]; then
      break
    fi

    if [[ "${arg}" =~ ^-[^-]*[it][^-]*$ ]]; then
      return 0
    fi

    case "${arg}" in
      -i|--interactive|-t|--tty|--interactive=*|--tty=*)
        return 0
        ;;
      -a|--attach)
        expecting_value=1
        ;;
      --attach=stdin|--attach=stdin,*|--attach=*,stdin|--attach=*,stdin,*)
        return 0
        ;;
      -*)
        ;;
      *)
        break
        ;;
    esac
  done

  return 1
}

podman_run_has_option() {
  local option_name="$1"
  shift
  local expecting_value=""
  local arg

  for arg in "$@"; do
    if [[ -n "${expecting_value}" ]]; then
      expecting_value=""
      continue
    fi

    if [[ "${arg}" == "--" ]]; then
      break
    fi

    case "${option_name}" in
      cgroups)
        case "${arg}" in
          --cgroups|--cgroups=*)
            return 0
            ;;
        esac
        ;;
      network)
        case "${arg}" in
          --network|--network=*|--net|--net=*)
            return 0
            ;;
        esac
        ;;
    esac

    if podman_run_option_expects_value "${arg}"; then
      expecting_value="${arg}"
      continue
    fi

    case "${arg}" in
      -*)
        ;;
      *)
        break
        ;;
    esac
  done

  return 1
}

podman_run_option_expects_value() {
  case "${1:-}" in
    --add-host|--annotation|--attach|--blkio-weight-device|--cgroup-parent|--cgroups|--cidfile|--conmon-pidfile|--cpus|--cpuset-cpus|--cpuset-mems|--device|--device-cgroup-rule|--device-read-bps|--device-read-iops|--device-write-bps|--device-write-iops|--dns|--dns-option|--dns-search|--entrypoint|--env|--env-file|--expose|--gidmap|--group-add|--health-cmd|--health-interval|--health-log-destination|--health-max-log-count|--health-max-log-size|--health-on-failure|--health-retries|--health-start-interval|--health-start-period|--health-timeout|--hostname|--hooks-dir|--ipc|--ip|--ip6|--label|--label-file|--log-driver|--log-opt|--mac-address|--memory|--memory-reservation|--memory-swap|--mount|--name|--network|--network-alias|--oom-score-adj|--pid|--platform|--pod|--publish|--pull|--restart|--runtime|--security-opt|--shm-size|--stop-signal|--stop-timeout|--storage-opt|--subgidname|--subuidname|--sysctl|--tmpfs|--ulimit|--uidmap|--user|--userns|--uts|--volume|--volumes-from|--workdir|-a|-c|-e|-h|-l|-m|-p|-u|-v|-w)
      return 0
      ;;
  esac

  return 1
}

podman_run_has_published_ports() {
  local expecting_value=""
  local arg

  for arg in "$@"; do
    if [[ -n "${expecting_value}" ]]; then
      expecting_value=""
      continue
    fi

    if [[ "${arg}" == "--" ]]; then
      break
    fi

    case "${arg}" in
      -p|--publish|-P|--publish-all|--publish=*|--publish-all=*|-p*)
        return 0
        ;;
      -*)
        if podman_run_option_expects_value "${arg}"; then
          expecting_value="${arg}"
        fi
        ;;
      *)
        break
        ;;
    esac
  done

  return 1
}

podman_build_has_option() {
  local option_name="$1"
  shift
  local expecting_value=""
  local arg

  for arg in "$@"; do
    if [[ -n "${expecting_value}" ]]; then
      expecting_value=""
      continue
    fi

    if [[ "${arg}" == "--" ]]; then
      break
    fi

    case "${option_name}" in
      isolation)
        case "${arg}" in
          --isolation|--isolation=*)
            return 0
            ;;
        esac
        ;;
    esac

    case "${arg}" in
      --isolation)
        expecting_value="${arg}"
        ;;
      -*)
        case "${arg}" in
          -f|--file|-t|--tag|--build-arg|--target|--cache-from|--cache-to|--secret|--ssh|--volume|--ulimit|--userns-uid-map|--userns-gid-map)
            expecting_value="${arg}"
            ;;
        esac
        ;;
      *)
        continue
        ;;
    esac
  done

  return 1
}

apply_default_run_options() {
  local default_cgroups="${CONTROL_PLANE_PODMAN_DEFAULT_CGROUPS:-}"
  local default_network="${CONTROL_PLANE_PODMAN_DEFAULT_NETWORK:-}"
  local updated_args=()

  command_args=("$@")
  [[ "${command_args[0]:-}" == "run" ]] || return 0

  updated_args=(run)
  if [[ -n "${default_cgroups}" ]] && ! podman_run_has_option cgroups "${command_args[@]:1}"; then
    updated_args+=("--cgroups=${default_cgroups}")
  fi
  if [[ -n "${default_network}" ]] \
    && ! podman_run_has_option network "${command_args[@]:1}" \
    && ! podman_run_has_published_ports "${command_args[@]:1}"; then
    updated_args+=("--network=${default_network}")
  fi
  updated_args+=("${command_args[@]:1}")
  command_args=("${updated_args[@]}")
}

apply_default_build_options() {
  local default_build_isolation="${CONTROL_PLANE_PODMAN_BUILD_ISOLATION:-}"
  local updated_args=()

  command_args=("$@")
  [[ "${command_args[0]:-}" == "build" ]] || return 0
  [[ -n "${default_build_isolation}" ]] || return 0
  podman_build_has_option isolation "${command_args[@]:1}" && return 0

  updated_args=(build "--isolation=${default_build_isolation}")
  updated_args+=("${command_args[@]:1}")
  command_args=("${updated_args[@]}")
}

podman_run_can_use_detached_workaround() {
  local workaround_mode="${CONTROL_PLANE_PODMAN_RUN_DETACH_WORKAROUND:-auto}"
  local expecting_value=0
  local arg

  [[ "${workaround_mode}" != "never" ]] || return 1
  if [[ "${workaround_mode}" != "always" ]]; then
    running_in_kubernetes || return 1
  fi

  [[ "${1:-}" == "run" ]] || return 1
  shift

  for arg in "$@"; do
    if [[ "${expecting_value}" -eq 1 ]]; then
      expecting_value=0
      continue
    fi

    if [[ "${arg}" == "--" ]]; then
      break
    fi

    if [[ "${arg}" =~ ^-[^-]*[it][^-]*$ ]]; then
      return 1
    fi

    case "${arg}" in
      -i|--interactive|-t|--tty|-d|--detach|--sig-proxy|--sig-proxy=*|--interactive=*|--tty=*|--detach=*)
        return 1
        ;;
      -a|--attach)
        expecting_value=1
        ;;
      --attach=*)
        if [[ "${arg}" == *=stdin* ]]; then
          return 1
        fi
        ;;
      --rm|--rm=true|--rm=false)
        ;;
      --cidfile|--cgroup-parent|--cgroups|--conmon-pidfile|--cpus|--cpuset-cpus|--device|--dns|--dns-option|--dns-search|--entrypoint|--env|--env-file|--group-add|--health-cmd|--health-on-failure|--health-start-period|--healthcheck-command|--hostname|--ip|--ipc|--label|--log-driver|--log-opt|--memory|--mount|--name|--network|--network-alias|--pid|--platform|--pod|--publish|--pull|--replace|--restart|--runtime|--security-opt|--shm-size|--stop-signal|--stop-timeout|--sysctl|--tmpfs|--ulimit|--user|--userns|--uts|--volume|--workdir|-c|-e|-h|-l|-m|-p|-u|-v|-w)
        expecting_value=1
        ;;
      --*=*)
        ;;
      -*)
        ;;
      *)
        break
        ;;
    esac
  done

  return 0
}

detached_run_args=()
detached_run_remove_after=0

prepare_detached_run_args() {
  local arg

  detached_run_args=(run -d)
  detached_run_remove_after=0

  for arg in "${@:2}"; do
    case "${arg}" in
      --rm|--rm=true)
        detached_run_remove_after=1
        ;;
      --rm=false)
        ;;
      *)
        detached_run_args+=("${arg}")
        ;;
    esac
  done
}

run_noninteractive_podman_run() {
  local stdout_path="$1"
  local stderr_path="$2"
  local cid=""
  local inspect_output=""
  local inspect_status=0
  local exit_code=""
  local running_state=""

  # shellcheck disable=SC2329
  stop_detached_container() {
    local signal_status="$1"

    if [[ -n "${cid}" ]]; then
      "${podman_bin}" stop --time 0 "${cid}" >/dev/null 2>&1 || true
      if [[ "${detached_run_remove_after}" -eq 1 ]]; then
        "${podman_bin}" rm -f "${cid}" >/dev/null 2>&1 || true
      fi
    fi

    exit "${signal_status}"
  }

  prepare_detached_run_args "${command_args[@]}"

  if run_podman_capture_stdout_live_stderr "${stdout_path}" "${stderr_path}" "${detached_run_args[@]}"; then
    :
  else
    local status=$?
    return "${status}"
  fi

  cid="$(tail -n 1 "${stdout_path}" | tr -d '\r\n')"
  if [[ -z "${cid}" ]]; then
    printf '%s\n' 'control-plane-podman: detached run did not return a container ID.' >&2
    return 125
  fi

  trap 'stop_detached_container 130' INT
  trap 'stop_detached_container 143' TERM

  while true; do
    set +e
    inspect_output="$("${podman_bin}" inspect --type container --format '{{.State.Running}} {{.State.ExitCode}}' "${cid}" 2>&1)"
    inspect_status=$?
    set -e

    if [[ "${inspect_status}" -ne 0 ]]; then
      trap - INT TERM
      printf '%s\n' "${inspect_output}" >&2
      return "${inspect_status}"
    fi

    running_state="${inspect_output%% *}"
    if [[ "${running_state}" == "false" ]]; then
      break
    fi

    sleep 0.2
  done

  trap - INT TERM

  "${podman_bin}" logs "${cid}"

  if [[ "${detached_run_remove_after}" -eq 1 ]]; then
    "${podman_bin}" rm -f "${cid}" >/dev/null 2>&1 || true
  fi

  exit_code="$(printf '%s\n' "${inspect_output}" | tail -n 1 | awk '{print $2}' | tr -d '\r\n')"
  case "${exit_code}" in
    ''|*[!0-9]*)
      # shellcheck disable=SC2016
      printf 'control-plane-podman: unexpected `podman inspect` output: %s\n' "${inspect_output}" >&2
      return 125
      ;;
  esac

  return "${exit_code}"
}

invoke_podman_command() {
  local stderr_path="$1"
  local stdout_path="$2"

  : > "${stdout_path}"
  if podman_run_can_use_detached_workaround "${command_args[@]}"; then
    run_noninteractive_podman_run "${stdout_path}" "${stderr_path}"
    return $?
  fi

  run_podman_with_live_stderr "${stderr_path}" "${command_args[@]}"
}

export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/tmp/podman-run-$(id -u)}"
export TMPDIR="${TMPDIR:-/tmp/control-plane-$(id -u)}"
mkdir -p "${XDG_RUNTIME_DIR}"
mkdir -p "${TMPDIR}"
chmod 700 "${XDG_RUNTIME_DIR}"
chmod 700 "${TMPDIR}"

apply_default_run_options "$@"
apply_default_build_options "${command_args[@]}"

if podman_command_needs_direct_exec "${command_args[@]}"; then
  exec "${podman_bin}" "${command_args[@]}"
fi

stdout_path="$(mktemp)"
stderr_path="$(mktemp)"
migrate_stderr_path="$(mktemp)"
trap 'rm -f "${stdout_path}" "${stderr_path}" "${migrate_stderr_path}"' EXIT

if invoke_podman_command "${stderr_path}" "${stdout_path}"; then
  exit 0
else
  status=$?
fi

if podman_requests_migrate "${stderr_path}"; then
  printf '%s\n' \
    "control-plane-podman: detected stale rootless Podman state; attempting \`podman system migrate\` once." \
    >&2
  if run_podman_with_live_stderr "${migrate_stderr_path}" system migrate; then
    if invoke_podman_command "${stderr_path}" "${stdout_path}"; then
      printf '%s\n' \
        "control-plane-podman: \`podman system migrate\` repaired the local Podman state." \
        >&2
      exit 0
    else
      status=$?
    fi
  fi
fi

if podman_reports_userns_failure "${stderr_path}" || podman_reports_userns_failure "${migrate_stderr_path}"; then
  printf '%s\n' \
    'control-plane-podman: rootless Podman is blocked by the outer runtime in this environment.' \
    'Re-adding capabilities inside the Pod may be necessary (for example SETFCAP on Linux 5.12+), but it is not sufficient on its own; the outer host/runtime still has to allow nested user namespaces, newuidmap/newgidmap, and the required seccomp/AppArmor/sysctl settings.' \
    'Prefer Kubernetes Jobs (CONTROL_PLANE_RUN_MODE=k8s-job or control-plane-run --mode k8s-job), GitHub Actions, or a host runner with a working rootless Podman setup.' \
    >&2
  if running_in_kubernetes && pod_uses_identity_user_namespace; then
    printf '%s\n' \
      "This Pod does not appear to be using Kubernetes Pod user namespaces. Enable \`spec.hostUsers: false\` when your cluster/runtime supports Pod user namespaces; otherwise nested rootless Podman often fails during re-exec." \
      >&2
  fi
  if running_in_kubernetes && [[ ! -e /dev/fuse ]]; then
    printf '%s\n' \
      "This Pod also lacks \`/dev/fuse\`, so local Podman will fall back to the \`vfs\` storage driver even after user namespace issues are resolved. Mount \`/dev/fuse\` or a compatible device-plugin resource when you want \`fuse-overlayfs\`." \
      >&2
  fi
fi

if running_in_kubernetes && { podman_reports_network_device_failure "${stderr_path}" || podman_reports_network_device_failure "${migrate_stderr_path}"; }; then
  # shellcheck disable=SC2016
  printf '%s\n' \
    'control-plane-podman: rootless Podman networking could not start because `slirp4netns` could not open `/dev/net/tun`.' \
    'Mount `/dev/net/tun` (or a compatible device-plugin resource) when you need default rootless networking inside the Pod, or use `--network=none` for networkless local runs.' \
    >&2
fi

if [[ "${CONTROL_PLANE_LOCAL_PODMAN_MODE:-}" == "rootful-service" ]] && { podman_reports_rootful_service_constraint "${stderr_path}" || podman_reports_rootful_service_constraint "${migrate_stderr_path}"; }; then
  printf '%s\n' \
    'control-plane-podman: the rootful Podman service is active, but the cluster still blocked one of its nested runtime requirements.' \
    "Use the current-cluster profile: capabilities add [AUDIT_WRITE, CHOWN, DAC_OVERRIDE, FOWNER, KILL, MKNOD, NET_ADMIN, SETFCAP, SETGID, SETPCAP, SETUID, SYS_ADMIN, SYS_CHROOT], seccomp/appArmor unconfined, and let the wrapper keep its default \`--cgroups=disabled --network=host\` flags unless you know the node runtime supports other combinations." \
    >&2
fi

exit "${status}"
