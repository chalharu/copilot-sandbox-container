Port 2222
Protocol 2
AddressFamily any
ListenAddress 0.0.0.0
# Job transfer pins the ED25519 host key into known_hosts; advertising multiple
# host key algorithms can make Go SSH clients select a different key type.
HostKey /etc/ssh/ssh_host_ed25519_key
PidFile /run/sshd.pid
PermitRootLogin no
AllowUsers copilot
PasswordAuthentication no
KbdInteractiveAuthentication no
ChallengeResponseAuthentication no
UsePAM no
PubkeyAuthentication yes
AuthorizedKeysFile .config/control-plane/ssh-auth/authorized_keys
PermitUserEnvironment no
AllowTcpForwarding yes
X11Forwarding no
PrintMotd no
UseDNS no
Subsystem sftp internal-sftp
