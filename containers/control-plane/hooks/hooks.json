{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "hook_script=\"${COPILOT_HOME:-${HOME}/.copilot}/hooks/audit/main.mjs\" && node \"$hook_script\" sessionStart",
        "cwd": ".",
        "timeoutSec": 30
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "hook_script=\"${COPILOT_HOME:-${HOME}/.copilot}/hooks/audit/main.mjs\" && node \"$hook_script\" userPromptSubmitted",
        "cwd": ".",
        "timeoutSec": 30
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "hook_script=\"${COPILOT_HOME:-${HOME}/.copilot}/hooks/audit/main.mjs\" && node \"$hook_script\" preToolUse",
        "cwd": ".",
        "timeoutSec": 30
      },
      {
        "type": "command",
        "bash": "hook_script=\"${COPILOT_HOME:-${HOME}/.copilot}/hooks/preToolUse/main\" && \"$hook_script\"",
        "cwd": ".",
        "timeoutSec": 30
      },
      {
        "type": "command",
        "bash": "hook_script=\"${COPILOT_HOME:-${HOME}/.copilot}/hooks/preToolUse/exec-forward.mjs\" && CONTROL_PLANE_HOOK_SESSION_KEY=\"$PPID\" node \"$hook_script\"",
        "cwd": ".",
        "timeoutSec": 150
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "hook_script=\"${COPILOT_HOME:-${HOME}/.copilot}/hooks/audit/main.mjs\" && node \"$hook_script\" postToolUse",
        "cwd": ".",
        "timeoutSec": 30
      },
      {
        "type": "command",
        "bash": "hook_script=\"${COPILOT_HOME:-${HOME}/.copilot}/hooks/postToolUse/main.mjs\" && node \"$hook_script\"",
        "cwd": ".",
        "timeoutSec": 30
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "hook_script=\"${COPILOT_HOME:-${HOME}/.copilot}/hooks/sessionEnd/cleanup.mjs\" && CONTROL_PLANE_HOOK_SESSION_KEY=\"$PPID\" node \"$hook_script\"",
        "cwd": ".",
        "timeoutSec": 30
      }
    ]
  }
}
