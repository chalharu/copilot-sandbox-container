{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "hook_script=\"${HOME}/.copilot/hooks/audit/main.mjs\" && node \"$hook_script\" sessionStart",
        "powershell": "$hookScript = Join-Path $HOME '.copilot/hooks/audit/main.mjs'; node $hookScript sessionStart",
        "cwd": ".",
        "timeoutSec": 30
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "hook_script=\"${HOME}/.copilot/hooks/audit/main.mjs\" && node \"$hook_script\" userPromptSubmitted",
        "powershell": "$hookScript = Join-Path $HOME '.copilot/hooks/audit/main.mjs'; node $hookScript userPromptSubmitted",
        "cwd": ".",
        "timeoutSec": 30
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "hook_script=\"${HOME}/.copilot/hooks/audit/main.mjs\" && node \"$hook_script\" preToolUse",
        "powershell": "$hookScript = Join-Path $HOME '.copilot/hooks/audit/main.mjs'; node $hookScript preToolUse",
        "cwd": ".",
        "timeoutSec": 30
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "hook_script=\"${HOME}/.copilot/hooks/audit/main.mjs\" && node \"$hook_script\" postToolUse",
        "powershell": "$hookScript = Join-Path $HOME '.copilot/hooks/audit/main.mjs'; node $hookScript postToolUse",
        "cwd": ".",
        "timeoutSec": 30
      },
      {
        "type": "command",
        "bash": "hook_script=\"${HOME}/.copilot/hooks/auditAnalysis/main.mjs\" && node \"$hook_script\"",
        "powershell": "$hookScript = Join-Path $HOME '.copilot/hooks/auditAnalysis/main.mjs'; node $hookScript",
        "cwd": ".",
        "timeoutSec": 30
      },
      {
        "type": "command",
        "bash": "hook_script=\"${HOME}/.copilot/hooks/postToolUse/main.mjs\" && node \"$hook_script\"",
        "powershell": "$hookScript = Join-Path $HOME '.copilot/hooks/postToolUse/main.mjs'; node $hookScript",
        "cwd": ".",
        "timeoutSec": 30
      }
    ]
  }
}
