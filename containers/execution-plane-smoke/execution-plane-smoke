#!/usr/bin/env bash
set -euo pipefail

action="${1:-report}"

case "${action}" in
  report)
    [[ -d /workspace ]] || {
      printf 'execution-plane-smoke: /workspace is missing\n' >&2
      exit 1
    }
    printf 'execution-plane=ready\n'
    printf 'workspace=/workspace\n'
    ;;
  write-marker)
    marker_path="${2:?marker path is required}"
    marker_value="${3:-ok}"
    mkdir -p "$(dirname "${marker_path}")"
    printf '%s\n' "${marker_value}" | tee "${marker_path}"
    ;;
  exec)
    shift
    exec "$@"
    ;;
  *)
    printf 'execution-plane-smoke: unknown action %s\n' "${action}" >&2
    exit 64
    ;;
esac
