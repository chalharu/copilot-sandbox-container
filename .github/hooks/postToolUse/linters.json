{
  "tools": [
    {
      "id": "markdownlint-fix",
      "command": "markdownlint-cli2",
      "args": [
        "--fix"
      ]
    },
    {
      "id": "markdownlint-fix-npx",
      "command": "npx",
      "args": [
        "--yes",
        "markdownlint-cli2",
        "--fix"
      ]
    },
    {
      "id": "markdownlint-check",
      "command": "markdownlint-cli2",
      "args": []
    },
    {
      "id": "markdownlint-check-npx",
      "command": "npx",
      "args": [
        "--yes",
        "markdownlint-cli2"
      ]
    },
    {
      "id": "biome-check-write",
      "command": "biome",
      "args": [
        "check",
        "--write"
      ]
    },
    {
      "id": "biome-check-write-npx",
      "command": "npx",
      "args": [
        "--yes",
        "@biomejs/biome",
        "check",
        "--write"
      ]
    },
    {
      "id": "biome-check",
      "command": "biome",
      "args": [
        "check"
      ]
    },
    {
      "id": "biome-check-npx",
      "command": "npx",
      "args": [
        "--yes",
        "@biomejs/biome",
        "check"
      ]
    },
    {
      "id": "oxlint-fix",
      "command": "oxlint",
      "args": [
        "--fix"
      ]
    },
    {
      "id": "oxlint-fix-npx",
      "command": "npx",
      "args": [
        "--yes",
        "oxlint",
        "--fix"
      ]
    },
    {
      "id": "oxlint-check",
      "command": "oxlint",
      "args": []
    },
    {
      "id": "oxlint-check-npx",
      "command": "npx",
      "args": [
        "--yes",
        "oxlint"
      ]
    },
    {
      "id": "eslint-fix",
      "command": "eslint",
      "args": [
        "--fix"
      ]
    },
    {
      "id": "eslint-fix-npx",
      "command": "npx",
      "args": [
        "--yes",
        "eslint",
        "--fix"
      ]
    },
    {
      "id": "eslint-check",
      "command": "eslint",
      "args": []
    },
    {
      "id": "eslint-check-npx",
      "command": "npx",
      "args": [
        "--yes",
        "eslint"
      ]
    },
    {
      "id": "ruff-format",
      "command": "ruff",
      "args": [
        "format"
      ]
    },
    {
      "id": "ruff-check-fix",
      "command": "ruff",
      "args": [
        "check",
        "--fix"
      ]
    },
    {
      "id": "ruff-check",
      "command": "ruff",
      "args": [
        "check"
      ]
    },
    {
      "id": "containerized-rust-fmt",
      "command": "bash",
      "args": [
        "containers/control-plane/skills/containerized-rust-ops/scripts/podman-rust.sh",
        "fmt"
      ],
      "appendFiles": false
    },
    {
      "id": "containerized-rust-clippy-fix",
      "command": "bash",
      "args": [
        "containers/control-plane/skills/containerized-rust-ops/scripts/podman-rust.sh",
        "clippy-fix"
      ],
      "appendFiles": false
    },
    {
      "id": "containerized-rust-clippy-check",
      "command": "bash",
      "args": [
        "containers/control-plane/skills/containerized-rust-ops/scripts/podman-rust.sh",
        "clippy"
      ],
      "appendFiles": false
    },
    {
      "id": "containerized-yamllint-check",
      "command": "bash",
      "args": [
        ".github/skills/containerized-yamllint-ops/scripts/podman-yamllint.sh"
      ]
    },
    {
      "id": "hadolint-check",
      "command": "hadolint",
      "args": []
    }
  ],
  "pipelines": [
    {
      "id": "markdown",
      "matcher": [
        "\\.(?:md|markdown)$"
      ],
      "steps": [
        {
          "tools": [
            "markdownlint-fix",
            "markdownlint-fix-npx"
          ]
        },
        {
          "tools": [
            "markdownlint-check",
            "markdownlint-check-npx"
          ],
          "reportFailure": true,
          "failureLabel": "Markdown linter reported unresolved issues:"
        }
      ]
    },
    {
      "id": "scripts",
      "matcher": [
        "\\.(?:[cm]?[jt]s|[jt]sx)$"
      ],
      "steps": [
        {
          "tools": [
            "biome-check-write",
            "biome-check-write-npx"
          ]
        },
        {
          "tools": [
            "oxlint-fix",
            "eslint-fix",
            "eslint-fix-npx",
            "oxlint-fix-npx"
          ]
        },
        {
          "tools": [
            "biome-check-write",
            "biome-check-write-npx"
          ]
        },
        {
          "tools": [
            "biome-check",
            "biome-check-npx"
          ],
          "reportFailure": true,
          "failureLabel": "Biome reported unresolved issues:"
        },
        {
          "tools": [
            "oxlint-check",
            "eslint-check",
            "eslint-check-npx",
            "oxlint-check-npx"
          ],
          "reportFailure": true,
          "failureLabel": "JavaScript/TypeScript linter reported unresolved issues:"
        }
      ]
    },
    {
      "id": "yaml",
      "matcher": [
        "\\.(?:ya?ml)$"
      ],
      "steps": [
        {
          "tools": [
            "containerized-yamllint-check"
          ],
          "reportFailure": true,
          "failureLabel": "Yamllint reported unresolved issues:"
        }
      ]
    },
    {
      "id": "python",
      "matcher": [
        "\\.(?:py|pyi|pyw)$"
      ],
      "steps": [
        {
          "tools": [
            "ruff-format"
          ]
        },
        {
          "tools": [
            "ruff-check-fix"
          ]
        },
        {
          "tools": [
            "ruff-format"
          ]
        },
        {
          "tools": [
            "ruff-check"
          ],
          "reportFailure": true,
          "failureLabel": "Ruff reported unresolved issues:"
        }
      ]
    },
    {
      "id": "rust",
      "matcher": [
        "\\.rs$"
      ],
      "steps": [
        {
          "tools": [
            "containerized-rust-fmt"
          ],
          "reportFailure": true,
          "failureLabel": "Containerized Rust formatter reported unresolved issues:"
        },
        {
          "tools": [
            "containerized-rust-clippy-fix"
          ]
        },
        {
          "tools": [
            "containerized-rust-fmt"
          ]
        },
        {
          "tools": [
            "containerized-rust-clippy-check"
          ],
          "reportFailure": true,
          "failureLabel": "Containerized Rust linter reported unresolved issues:"
        }
      ]
    },
    {
      "id": "dockerfile",
      "matcher": [
        "(?:^|/)Dockerfile(?:\\.[^/]+)?$",
        "(?:^|/)[^/]+\\.Dockerfile$"
      ],
      "steps": [
        {
          "tools": [
            "hadolint-check"
          ],
          "reportFailure": true,
          "failureLabel": "Hadolint reported unresolved issues:"
        }
      ]
    }
  ]
}
